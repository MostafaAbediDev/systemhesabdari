<UserControl x:Class="Taadol.Controls.PersianDatePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">

    <StackPanel Orientation="Horizontal">

        <!-- سال -->
        <TextBox x:Name="PART_Day"
                 Style="{StaticResource ModernPersianTextBox}"
                 Width="50"
                 Tag="روز"
                 MaxLength="2"
                 TextChanged="DayTextBox_TextChanged"
                 GotFocus="DateTextBox_GotFocus" />
        <Rectangle Width="3" />

        <!-- ماه -->
        <TextBox x:Name="PART_Month"
                 Style="{StaticResource ModernPersianTextBox}"
                 Width="55"
                 Tag="ماه"
                 MaxLength="2"
                 TextChanged="MonthTextBox_TextChanged"
                 GotFocus="DateTextBox_GotFocus" />

        <Rectangle Width="3" />

        <!-- روز -->
        <TextBox x:Name="PART_Year"
                 Style="{StaticResource ModernPersianTextBox}"
                 Width="70"
                 Tag="سال"
                 MaxLength="4"
                 TextChanged="YearTextBox_TextChanged"
                 GotFocus="DateTextBox_GotFocus" />


        <Rectangle Width="5" />

        <!-- دکمه تقویم -->
        <Button x:Name="PART_CalendarButton"
                Width="45"
                Height="45"
                Cursor="Hand"
                Click="TodayButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="White"
                            BorderBrush="#2667FF"
                            BorderThickness="0.5,0.5,0.5,2"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#F0F4FF" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="#DCE8FF" />
                            <Setter TargetName="ButtonBorder"
                                    Property="BorderThickness"
                                    Value="1,1,1,2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>

