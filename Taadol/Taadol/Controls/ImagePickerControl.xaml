<UserControl x:Class="Taadol.Controls.ImagePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200"
             d:DesignWidth="210">

    <!-- ─── باکس اصلی ─── -->
    <Border x:Name="ImageBorder"
            Width="195"
            Height="195"
            Padding="5"
            CornerRadius="12"
            BorderThickness="1.5"
            BorderBrush="#BED1FF"
            Background="#F8FAFF"
            ClipToBounds="True"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">

        <Grid>

            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   Visibility="Collapsed"
                   HorizontalAlignment="Stretch"
                   ClipToBounds="True"
                   VerticalAlignment="Stretch" />



            <StackPanel x:Name="PlaceholderPanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,0">
                <svg:SvgViewbox x:Name="PlaceholderIcon"
                                Width="56"
                                Height="56"
                                HorizontalAlignment="Center" />
                <TextBlock Text="بدون تصویر"
                           FontSize="12"
                           Foreground="#94A3B8"
                           FontFamily="{StaticResource IRANSans}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <Grid FlowDirection="RightToLeft">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />

                </Grid.ColumnDefinitions>
                <Border x:Name="ActionButton"
                        Grid.Column="0"
                        Height="35"
                        Width="35"
                        CornerRadius="8"
                        BorderThickness="0.8,0.8,0.8,2"
                        Cursor="Hand"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        BorderBrush="#BED1FF"
                        Background="#FFFFFF"
                        MouseLeftButtonUp="ActionButton_Click"
                        MouseEnter="ActionButton_MouseEnter"
                        MouseLeave="ActionButton_MouseLeave">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8"
                                          ShadowDepth="2"
                                          Direction="270"
                                          Color="#000000"
                                          Opacity="0.08" />
                    </Border.Effect>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,0">

                        <svg:SvgViewbox x:Name="ButtonIcon"
                                        Width="12"
                                        Height="12"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,0" />


                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Border>

</UserControl>
