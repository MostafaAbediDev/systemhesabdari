<UserControl x:Class="Taadol.Controls.OutlinedIconButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
             x:Name="Root">

    <Button Command="{Binding ButtonCommand, ElementName=Root}"
            Click="Button_Click"
            Background="{Binding ButtonBackground, ElementName=Root}"
            BorderBrush="{Binding ButtonBorderBrush, ElementName=Root}"
            BorderThickness="{Binding ButtonBorderThickness, ElementName=Root}"
            Height="{Binding ButtonHeight, ElementName=Root}"
            Width="{Binding ButtonWidth, ElementName=Root}"
            Margin="{Binding ButtonMargin, ElementName=Root}">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding CornerRadius, ElementName=Root}"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver"
                             Value="True">
                        <Setter TargetName="border"
                                Property="Background"
                                Value="{Binding HoverBackground, ElementName=Root}" />
                    </Trigger>
                    <Trigger Property="IsPressed"
                             Value="True">
                        <Setter TargetName="border"
                                Property="Background"
                                Value="{Binding PressedBackground, ElementName=Root}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>

        <StackPanel Orientation="Horizontal">
            <svg:SvgViewbox Width="{Binding IconSize, ElementName=Root}"
                            Height="{Binding IconSize, ElementName=Root}"
                            Source="{Binding IconSource, ElementName=Root}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Visibility="{Binding IconVisibility, ElementName=Root}" />
            <TextBlock Text="{Binding ButtonText, ElementName=Root}"
                       FontSize="{Binding TextSize, ElementName=Root}"
                       FontWeight="{Binding TextWeight, ElementName=Root}"
                       Foreground="{Binding TextForeground, ElementName=Root}"
                       FontFamily="{StaticResource IRANSans}"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>