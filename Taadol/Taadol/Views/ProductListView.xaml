<UserControl x:Class="Taadol.Views.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             d:DesignHeight="650"
             d:DesignWidth="1440"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Margin="24"
             FlowDirection="RightToLeft"
             FontFamily="{StaticResource IRANSans}"
             Background="#FFFFFF">

    <Border Margin="24,16"
            Background="White"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--============ HEADER ============-->
            <Border Grid.Row="0"
                    Padding="24,18"
                    Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox Width="18"
                                        Height="18"
                                        Source="/Assets/Icons/arrow-right.svg"
                                        VerticalAlignment="Center"
                                        Margin="0,0,12,0" />
                        <TextBlock Text="کالاها و خدمات"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="#001242"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="RightToLeft">
                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnMore_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/MORE.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnDelete_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/trash.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#FEF2F2" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnEdit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/EDIT.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnNew_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/newdoc.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0FFF4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Height="1"
                    Background="#E9F0FF"
                    VerticalAlignment="Bottom" />

            <!--============ DATAGRID ============-->
            <DataGrid x:Name="ProductsDataGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      VerticalGridLinesBrush="#E9F0FF"
                      HorizontalGridLinesBrush="#F1F5F9"
                      RowHeight="44"
                      Background="White"
                      BorderThickness="0"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      AlternationCount="2"
                      IsReadOnly="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                      FontFamily="{StaticResource IRANSans}">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"
                                Value="#F8FAFF" />
                        <Setter Property="Foreground"
                                Value="#64748B" />
                        <Setter Property="FontSize"
                                Value="13" />
                        <Setter Property="FontWeight"
                                Value="Medium" />
                        <Setter Property="FontFamily"
                                Value="{StaticResource IRANSans}" />
                        <Setter Property="Padding"
                                Value="12" />
                        <Setter Property="BorderBrush"
                                Value="#E9F0FF" />
                        <Setter Property="BorderThickness"
                                Value="0,0,1,1" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Center" />
                        <Setter Property="Height"
                                Value="48" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="Foreground"
                                Value="#334155" />
                        <Setter Property="FontSize"
                                Value="13" />
                        <Setter Property="FontFamily"
                                Value="{StaticResource IRANSans}" />
                        <Setter Property="BorderBrush"
                                Value="#E9F0FF" />
                        <Setter Property="BorderThickness"
                                Value="0,0,1,0" />
                        <Setter Property="Padding"
                                Value="12,0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#E8F2FF" />
                                <Setter Property="Foreground"
                                        Value="#2667FF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background"
                                Value="White" />
                        <Setter Property="Cursor"
                                Value="Hand" />
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex"
                                     Value="1">
                                <Setter Property="Background"
                                        Value="#F8FBFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#F0F5FF" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#E8F2FF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"
                                        Width="55"
                                        Binding="{Binding RowNumber}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#94A3B8" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="کد"
                                        Width="90"
                                        Binding="{Binding Code}" />

                    <DataGridTextColumn Header="دسته بندی"
                                        Width="120"
                                        Binding="{Binding Category}" />

                    <DataGridTextColumn Header="نام کالا"
                                        Width="140"
                                        Binding="{Binding ProductName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                                <Setter Property="Foreground"
                                        Value="#1E293B" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="بارکد"
                                        Width="100"
                                        Binding="{Binding Barcode}" />

                    <DataGridTextColumn Header="کد کالا"
                                        Width="130"
                                        Binding="{Binding ProductCode}" />

                    <DataGridTextColumn Header="واحد"
                                        Width="80"
                                        Binding="{Binding Unit}" />

                    <DataGridTextColumn Header="تعداد"
                                        Width="80"
                                        Binding="{Binding Quantity}" />

                    <DataGridTemplateColumn Header="وضعیت"
                                            Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="10,4"
                                        Visibility="{Binding StatusVisibility}">
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               FontFamily="{StaticResource IRANSans}"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="توضیحات"
                                        Width="100"
                                        Binding="{Binding Description}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="#94A3B8" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="قیمت خرید"
                                        Width="140"
                                        Binding="{Binding PurchasePriceFormatted}" />

                    <DataGridTextColumn Header="قیمت فروش"
                                        Width="140"
                                        Binding="{Binding SalePriceFormatted}" />

                    <DataGridTextColumn Header="مالیات"
                                        Width="120"
                                        Binding="{Binding TaxFormatted}" />
                </DataGrid.Columns>
            </DataGrid>

            <!--============ PAGINATION ============-->
            <Border Grid.Row="2"
                    Padding="24,14"
                    Background="White"
                    BorderBrush="#E9F0FF"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Pagination Controls - سمت چپ -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="LeftToRight">

                        <!-- دکمه قبلی -->
                        <!-- دکمه قبلی -->
                        <Button Width="34"
                                Height="34"
                                Margin="0,0,2,0"
                                Cursor="Hand"
                                Click="BtnPrevPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <!-- اضافه کردن BorderBrush برای تست دیدن کادر -->
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30"
                                            BorderBrush="Transparent"
                                            Background="Transparent">

                                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                                        Width="30"
                                                        Height="30"
                                                        Source="/Assets/Icons/Leftsquare.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- شماره ۱۰ -->
                        <Button Width="32"
                                Height="32"
                                Margin="0,0"
                                Cursor="Hand"
                                Click="BtnPage_Click"
                                Tag="10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                        <TextBlock Text="۱۰"
                                                   FontSize="14"
                                                   Foreground="#94A3B8"
                                                   FontFamily="{StaticResource IRANSans}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ... -->
                        <Border Width="28"
                                Height="32"
                                Margin="0,0">
                            <TextBlock Text="..."
                                       FontSize="14"
                                       Foreground="#94A3B8"
                                       FontFamily="{StaticResource IRANSans}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- شماره ۴ -->
                        <Button Width="32"
                                Height="32"
                                Margin="0,0"
                                Cursor="Hand"
                                Click="BtnPage_Click"
                                Tag="4">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                        <TextBlock Text="۴"
                                                   FontSize="14"
                                                   Foreground="#94A3B8"
                                                   FontFamily="{StaticResource IRANSans}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- شماره ۳ -->
                        <Button Width="32"
                                Height="32"
                                Margin="0,0"
                                Cursor="Hand"
                                Click="BtnPage_Click"
                                Tag="3">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                        <TextBlock Text="۳"
                                                   FontSize="14"
                                                   Foreground="#94A3B8"
                                                   FontFamily="{StaticResource IRANSans}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- شماره ۲ -->
                        <Button Width="32"
                                Height="32"
                                Margin="0,0"
                                Cursor="Hand"
                                Click="BtnPage_Click"
                                Tag="2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                        <TextBlock Text="۲"
                                                   FontSize="14"
                                                   Foreground="#94A3B8"
                                                   FontFamily="{StaticResource IRANSans}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- شماره ۱ (فعال) -->
                        <Button Width="32"
                                Height="32"
                                Margin="0,0"
                                Cursor="Hand"
                                Click="BtnPage_Click"
                                Tag="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                        <TextBlock Text="۱"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#001242"
                                                   FontFamily="{StaticResource IRANSans}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- دکمه بعدی -->
                        <Button Width="34"
                                Height="34"
                                Margin="2,0,0,0"
                                Cursor="Hand"
                                Click="BtnNextPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30">
                                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                                        Width="30"
                                                        Height="30"
                                                        Source="/Assets/Icons/Rightsquare.svg"
                                                        Margin="0,0,0,0" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- فاصله -->
                        <Border Width="12" />


                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>