                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="Transparent" />

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding AccountStatus}"
                                                                     Value="بدهکار">
                                                         
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding AccountStatus}"
                                                                     Value="بستانکار">
                                                          
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding AccountStatus}"
                                                                     Value="تسویه">
                                                          
                                                        </DataTrigger>

                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding AccountStatus}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       FontFamily="{StaticResource IRANSans}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
