<!-- Themes/Styles.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:svg="http://sharpvectors.codeplex.com/svgc/">

    <!-- ═══════════════════════════════════════════════ -->
    <!--         پالت رنگ سفارشی از فیگما                -->
    <!-- ═══════════════════════════════════════════════ -->

    <!-- Primary سرمه‌ای -->
    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="#0D2159" />
    <SolidColorBrush x:Key="PrimaryDarkBrush"
                     Color="#000B2E" />
    <SolidColorBrush x:Key="PrimaryLightBrush"
                     Color="#E9F0FF" />

    <!-- Accent آبی -->
    <SolidColorBrush x:Key="AccentBrush"
                     Color="#2667FF" />
    <SolidColorBrush x:Key="AccentDarkBrush"
                     Color="#1E52CC" />
    <SolidColorBrush x:Key="AccentDeepBrush"
                     Color="#173E99" />
    <SolidColorBrush x:Key="AccentLightBrush"
                     Color="#D4E1FF" />
    <SolidColorBrush x:Key="AccentSuperLightBrush"
                     Color="#E9F0FF" />
    <SolidColorBrush x:Key="MenuActiveBrush"
                     Color="#2667FF" />
    <SolidColorBrush x:Key="MenuInactiveBrush"
                     Color="#AFAFAF" />
    <!-- سبز -->
    <SolidColorBrush x:Key="GreenBrush"
                     Color="#02CF54" />
    <SolidColorBrush x:Key="GreenDarkBrush"
                     Color="#02A844" />
    <SolidColorBrush x:Key="GreenLightBrush"
                     Color="#E0FBEC" />


    <!-- قرمز -->
    <SolidColorBrush x:Key="DangerBrush"
                     Color="#C1121F" />
    <SolidColorBrush x:Key="DangerLightBrush"
                     Color="#FCE8EA" />

    <!-- طلایی -->
    <SolidColorBrush x:Key="GoldBrush"
                     Color="#F5A623" />
    <SolidColorBrush x:Key="GoldLightBrush"
                     Color="#FFF8E7" />

    <!-- طیف خاکستری آبی -->
    <SolidColorBrush x:Key="Gray05Brush"
                     Color="#E9F0FF" />
    <SolidColorBrush x:Key="Gray1Brush"
                     Color="#D4E1FF" />
    <SolidColorBrush x:Key="Gray15Brush"
                     Color="#BED1FF" />
    <SolidColorBrush x:Key="Gray2Brush"
                     Color="#A8C2FF" />
    <SolidColorBrush x:Key="Gray3Brush"
                     Color="#7DA4FF" />
    <SolidColorBrush x:Key="Gray4Brush"
                     Color="#5185FF" />
    <SolidColorBrush x:Key="Gray6Brush"
                     Color="#1E52CC" />
    <SolidColorBrush x:Key="Gray7Brush"
                     Color="#173E99" />
    <SolidColorBrush x:Key="Gray055Brush"
                     Color="#F8FAFC" />
    <!-- پس‌زمینه -->
    <SolidColorBrush x:Key="BackgroundBrush"
                     Color="#F2F5FA" />
    <SolidColorBrush x:Key="CardBackgroundBrush"
                     Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarBgBrush"
                     Color="#F8FAFF" />

    <!-- متن -->
    <SolidColorBrush x:Key="ActiveMenuBrush"
                     Color="#E9F0FF" />

    <SolidColorBrush x:Key="TextPrimaryBrush"
                     Color="#001242" />
    <SolidColorBrush x:Key="TextSecondaryBrush"
                     Color="#173E99" />
    <SolidColorBrush x:Key="TextMutedBrush"
                     Color="#A8C2FF" />

    <!-- حاشیه -->
    <SolidColorBrush x:Key="BorderBrush"
                     Color="#D4E1FF" />

    <!-- فونت -->
    <FontFamily x:Key="IRANSans">
        pack://application:,,,/Assets/Fonts/#IRANSansXFaNum
    </FontFamily>

    <Style x:Key="FilterTabStyle"
           TargetType="RadioButton">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="13" />
        <Setter Property="Foreground"
                Value="#64748B" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Margin"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd"
                            Background="Transparent"
                            BorderThickness="0,0,0,2.5"
                            BorderBrush="Transparent"
                            Padding="22,11"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <!--✅ چک‌مارک آیکون (فقط در حالت فعال نمایش داده میشه) -->
                            <Border x:Name="checkIcon"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="#22C55E"
                                    Margin="0,0,7,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <svg:SvgViewbox x:Name="CheckMark"
                                                Width="8"
                                                Height="8"
                                                Source="/Assets/Icons/Line.svg"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed" />
                            </Border>

                            <!-- متن تب -->
                            <TextBlock x:Name="txt"
                                       Text="{TemplateBinding Content}"
                                       VerticalAlignment="Center"
                                       FontWeight="Medium"
                                       FontFamily="{StaticResource IRANSans}" />

                            <!-- تعداد نفرات -->
                            <Border x:Name="countBorder"
                                    Background="#F1F5F9"
                                    CornerRadius="8"
                                    Padding="8,3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="countText"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="11"
                                           Foreground="#94A3B8"
                                           FontFamily="{StaticResource IRANSans}" />
                            </Border>


                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- حالت فعال (انتخاب شده) -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="txt"
                                    Property="Foreground"
                                    Value="#1E40AF" />
                            <Setter TargetName="txt"
                                    Property="FontWeight"
                                    Value="Bold" />
                            <Setter TargetName="bd"
                                    Property="BorderBrush"
                                    Value="#3B82F6" />
                            <Setter TargetName="bd"
                                    Property="Background"
                                    Value="#F0F7FF" />
                            <Setter TargetName="countBorder"
                                    Property="Background"
                                    Value="#DBEAFE" />
                            <Setter TargetName="countText"
                                    Property="Foreground"
                                    Value="#2563EB" />
                            <Setter TargetName="checkIcon"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>

                        <!-- حالت هاور -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="bd"
                                    Property="Background"
                                    Value="#F8FAFC" />
                        </Trigger>

                        <!-- هاور + فعال -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked"
                                           Value="True" />
                                <Condition Property="IsMouseOver"
                                           Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="bd"
                                    Property="Background"
                                    Value="#E8F1FF" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ═══════════════════════════════════════════════ -->
    <!--              استایل پنجره اصلی                  -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style x:Key="MainWindowStyle"
           TargetType="Window">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FlowDirection"
                Value="RightToLeft" />
        <Setter Property="Background"
                Value="{StaticResource BackgroundBrush}" />
        <Setter Property="FontSize"
                Value="13" />
    </Style>
    <Style x:Key="ModernCheckBox"
           TargetType="CheckBox">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="15" />
        <Setter Property="FontWeight"
                Value="DemiBold" />
        <Setter Property="Foreground"
                Value="#001242" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="FlowDirection"
                Value="RightToLeft" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- متن -->
                        <ContentPresenter Grid.Column="0"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          RecognizesAccessKey="True" />

                        <!-- چک‌باکس -->
                        <Border x:Name="CheckBoxBorder"
                                Grid.Column="1"
                                Width="22"
                                Height="22"
                                Background="White"
                                BorderBrush="#D4E0FF"
                                BorderThickness="1.5"
                                CornerRadius="6"
                                HorizontalAlignment="Right">

                            <!-- علامت تیک -->
                            <Path x:Name="CheckMark"
                                  Data="M 2 6 L 6 10 L 14 2"
                                  Stroke="#2667FF"
                                  StrokeThickness="2.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="Uniform"
                                  Margin="3"
                                  Opacity="0"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="CheckMarkScale"
                                                    ScaleX="0"
                                                    ScaleY="0" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- حالت Checked -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="CheckBoxBorder"
                                    Property="Background"
                                    Value="#E8F2FF" />
                            <Setter TargetName="CheckBoxBorder"
                                    Property="BorderBrush"
                                    Value="#2667FF" />
                            <Setter TargetName="CheckMark"
                                    Property="Opacity"
                                    Value="1" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut"
                                                          Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut"
                                                          Amplitude="0.3" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0"
                                                         Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- حالت Hover -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="CheckBoxBorder"
                                    Property="BorderBrush"
                                    Value="#2667FF" />
                        </Trigger>

                        <!-- حالت Disabled -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Opacity"
                                    Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="FilterTabStyle2"
           TargetType="RadioButton">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="12" />
        <Setter Property="Width"
                Value="215" />
        <Setter Property="Foreground"
                Value="#2563EB" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderBrush"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Padding"
                Value="16,10" />
        <Setter Property="Margin"
                Value="0,0,4,0" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Root"
                            Background="Transparent"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- چک‌باکس و عنوان (سمت راست) -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Border x:Name="CheckBoxBorder"
                                        Width="20"
                                        Height="20"
                                        BorderThickness="2"
                                        BorderBrush="#2ECC71"
                                        CornerRadius="4"
                                        Background="White"
                                        Padding="2"
                                        Margin="0,0,6,0"
                                        Visibility="Collapsed">
                                    <svg:SvgViewbox x:Name="CheckMark"
                                                    Width="8"
                                                    Height="8"
                                                    Source="/Assets/Icons/Line.svg"
                                                    FlowDirection="LeftToRight"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                </Border>

                                <TextBlock x:Name="TitleText"
                                           Text="{TemplateBinding Content}"
                                           Foreground="#2563EB"
                                           FontWeight="Medium" />
                            </StackPanel>

                            <!-- تعداد (سمت چپ) -->
                            <TextBlock Grid.Column="2"
                                       x:Name="CountText"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="#94A3B8"
                                       FontWeight="Normal"
                                       HorizontalAlignment="Left" />
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- حالت انتخاب شده -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="Root"
                                    Property="Background"
                                    Value="Transparent" />
                            <Setter TargetName="Root"
                                    Property="BorderBrush"
                                    Value="#2563EB" />
                            <Setter TargetName="Root"
                                    Property="BorderThickness"
                                    Value="1" />

                            <Setter TargetName="TitleText"
                                    Property="Foreground"
                                    Value="#2563EB" />
                            <Setter TargetName="TitleText"
                                    Property="FontWeight"
                                    Value="Bold" />
                            <Setter TargetName="CountText"
                                    Property="Foreground"
                                    Value="#64748B" />

                            <!-- نمایش چک‌باکس هنگام انتخاب -->
                            <Setter TargetName="CheckBoxBorder"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked"
                                 Value="False">
                            <Setter TargetName="Root"
                                    Property="Background"
                                    Value="Transparent" />
                            <Setter TargetName="Root"
                                    Property="BorderBrush"
                                    Value="#E9F0FF" />
                            <Setter TargetName="Root"
                                    Property="BorderThickness"
                                    Value="1" />

                            <Setter TargetName="TitleText"
                                    Property="Foreground"
                                    Value="#2563EB" />
                            <Setter TargetName="TitleText"
                                    Property="FontWeight"
                                    Value="Bold" />
                            <Setter TargetName="CountText"
                                    Property="Foreground"
                                    Value="#64748B" />
                        </Trigger>
                        <!-- حالت Hover -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Root"
                                    Property="Background"
                                    Value="#F4F7FF" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter TargetName="TitleText"
                                    Property="Foreground"
                                    Value="#CBD5E1" />
                            <Setter TargetName="CountText"
                                    Property="Foreground"
                                    Value="#E2E8F0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!-- ═══════════════════════════════════════════════ -->
    <!--              Card Panel                         -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style x:Key="CardPanel"
           TargetType="Border">
        <Setter Property="Background"
                Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="Padding"
                Value="18,10,5,0" />
        <Setter Property="Margin"
                Value="0,0,0,8" />
        <Setter Property="CornerRadius"
                Value="16" />

    </Style>
    <Style x:Key="OutlinedButtonLarge"
           TargetType="Button">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="16" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#F0F5FF" />
                        </Trigger>
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#E0EBFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="FormLabel"
           TargetType="TextBlock">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="18" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="Foreground"
                Value="#001242" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="0,0,0,2" />
    </Style>
    <Style x:Key="ModernPersianTextBox"
           TargetType="TextBox">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="Foreground"
                Value="#0D2159" />
        <Setter Property="Background"
                Value="#FFFFFF" />
        <Setter Property="BorderBrush"
                Value="#E8E8E8" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Padding"
                Value="16,12" />
        <Setter Property="Height"
                Value="45" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />
        <Setter Property="FlowDirection"
                Value="RightToLeft" />
        <Setter Property="CaretBrush"
                Value="#2667FF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <!-- Border اصلی -->
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Margin="{TemplateBinding Padding}" />

                                <!-- Placeholder -->
                                <TextBlock x:Name="PlaceholderText"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#BFBFBF"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           Margin="{TemplateBinding Padding}"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- نمایش Placeholder وقتی خالی است -->
                        <Trigger Property="Text"
                                 Value="">
                            <Setter TargetName="PlaceholderText"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>

                        <!-- تغییر رنگ border در حالت Focus -->
                        <Trigger Property="IsFocused"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="#2667FF" />
                            <Setter TargetName="border"
                                    Property="BorderThickness"
                                    Value="1.5" />
                        </Trigger>

                        <!-- حالت غیرفعال -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Background"
                                    Value="#F5F5F5" />
                            <Setter Property="Foreground"
                                    Value="#BFBFBF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SearchableComboBox"
           TargetType="ComboBox">
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="Foreground"
                Value="#0D2159" />
        <Setter Property="Background"
                Value="#FFFFFF" />
        <Setter Property="BorderBrush"
                Value="#E8E8E8" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Height"
                Value="48" />
        <Setter Property="Padding"
                Value="16,0" />
        <Setter Property="IsEditable"
                Value="True" />
        <Setter Property="IsTextSearchEnabled"
                Value="True" />
        <Setter Property="StaysOpenOnEdit"
                Value="True" />
        <Setter Property="FlowDirection"
                Value="RightToLeft" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- TextBox برای جستجو -->
                                <TextBox x:Name="PART_EditableTextBox"
                                         Grid.Column="0"
                                         Margin="{TemplateBinding Padding}"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         FontFamily="{TemplateBinding FontFamily}"
                                         FontSize="{TemplateBinding FontSize}"
                                         CaretBrush="#2667FF"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Focusable="True">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      Focusable="False"
                                                                      HorizontalScrollBarVisibility="Hidden"
                                                                      VerticalScrollBarVisibility="Hidden" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Placeholder -->
                                <TextBlock x:Name="PlaceholderText"
                                           Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#BFBFBF"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"
                                           Margin="{TemplateBinding Padding}"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />

                                <!-- دکمه dropdown -->
                                <ToggleButton x:Name="ToggleButton"
                                              Grid.Column="1"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"
                                              Width="40"
                                              Height="{TemplateBinding Height}"
                                              xmlns:svg="http://sharpvectors.codeplex.com/svgc/">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <svg:SvgViewbox x:Name="Arrow"
                                                                Width="13"
                                                                Height="13"
                                                                Source="/Assets/Icons/arrowDown.svg"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                RenderTransformOrigin="0.5,0.5">
                                                    <svg:SvgViewbox.RenderTransform>
                                                        <RotateTransform x:Name="ArrowRotation"
                                                                         Angle="0" />
                                                    </svg:SvgViewbox.RenderTransform>
                                                </svg:SvgViewbox>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked"
                                                         Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="ArrowRotation"
                                                                                 Storyboard.TargetProperty="Angle"
                                                                                 To="180"
                                                                                 Duration="0:0:0.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="ArrowRotation"
                                                                                 Storyboard.TargetProperty="Angle"
                                                                                 To="0"
                                                                                 Duration="0:0:0.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- Popup -->
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="Slide">
                                    <Border Background="White"
                                            BorderBrush="#E8E8E8"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,4,0,0"
                                            MaxHeight="250">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000"
                                                              Opacity="0.1"
                                                              BlurRadius="10"
                                                              ShadowDepth="2" />
                                        </Border.Effect>
                                        <ScrollViewer>
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- نمایش Placeholder -->
                        <Trigger Property="Text"
                                 Value="">
                            <Setter TargetName="PlaceholderText"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>
                        <Trigger Property="Text"
                                 Value="{x:Null}">
                            <Setter TargetName="PlaceholderText"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>

                        <!-- Focus state -->
                        <Trigger Property="IsKeyboardFocusWithin"
                                 Value="True">
                            <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="#2667FF" />
                            <Setter TargetName="border"
                                    Property="BorderThickness"
                                    Value="1.5" />
                        </Trigger>

                        <!-- Disabled state -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Background"
                                    Value="#F5F5F5" />
                            <Setter Property="Foreground"
                                    Value="#BFBFBF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


