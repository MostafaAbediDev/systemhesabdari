    <Style x:Key="StatusToggleButton"
           TargetType="ToggleButton">
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- متن قابل تغییر -->
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize"
                                            Value="16" />
                                    <Setter Property="FontWeight"
                                            Value="Medium" />
                                    <Setter Property="FontFamily"
                                            Value="{StaticResource IRANSans}" />
                                    <Setter Property="Foreground"
                                            Value="#2B3F6C" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>

                        <!-- کادر چک‌باکس -->
                        <Border x:Name="CheckBoxBorder"
                                Width="20"
                                Height="20"
                                BorderThickness="2"
                                BorderBrush="#BDC3C7"
                                CornerRadius="4"
                                Background="White"
                                Padding="2">
                            <!-- تیک SVG -->
                            <svg:SvgViewbox x:Name="CheckMark"
                                            Width="8"
                                            Height="8"
                                            Source="/Assets/Icons/Line.svg"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed" />
                        </Border>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <!-- وقتی checked است -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="CheckBoxBorder"
                                    Property="BorderBrush"
                                    Value="#2ECC71" />
                            <Setter TargetName="CheckBoxBorder"
                                    Property="Background"
                                    Value="White" />
                            <Setter TargetName="CheckMark"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>

                        <!-- وقتی unchecked است -->
                        <Trigger Property="IsChecked"
                                 Value="False">
                            <Setter TargetName="CheckBoxBorder"
                                    Property="BorderBrush"
                                    Value="#BDC3C7" />
                            <Setter TargetName="CheckBoxBorder"
                                    Property="Background"
                                    Value="White" />
                            <Setter TargetName="CheckMark"
                                    Property="Visibility"
                                    Value="Collapsed" />
                        </Trigger>

                        <!-- حالت MouseOver -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="CheckBoxBorder"
                                    Property="BorderBrush"
                                    Value="#27AE60" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="GreenRadioButtonStyle"
           TargetType="RadioButton">
        <Setter Property="Foreground"
                Value="#001242" />
        <Setter Property="FontSize"
                Value="14" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="FontFamily"
                Value="{StaticResource IRANSans}" />
        <Setter Property="FontWeight"
                Value="Medium" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- دایره بیرونی -->
                        <Ellipse x:Name="OuterCircle"
                                 Width="20"
                                 Height="20"
                                 Stroke="#E8E8E8"
                                 StrokeThickness="1"
                                 Fill="Transparent"
                                 Grid.Column="0" />

                        <!-- دایره داخلی (نقطه انتخاب) -->
                        <Ellipse x:Name="InnerCircle"
                                 Width="10"
                                 Height="10"
                                 Fill="#27AE60"
                                 Grid.Column="0"
                                 Visibility="Collapsed" />

                        <!-- متن -->
                        <ContentPresenter Grid.Column="1"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center" />
                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- حالت انتخاب شده -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="InnerCircle"
                                    Property="Visibility"
                                    Value="Visible" />
                            <Setter TargetName="OuterCircle"
                                    Property="Fill"
                                    Value="#E8F8F0" />
                            <Setter TargetName="OuterCircle"
                                    Property="Stroke"
                                    Value="#27AE60" />
                        </Trigger>

                        <!-- حالت هاور -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="OuterCircle"
                                    Property="Stroke"
                                    Value="#1E8449" />
                            <Setter TargetName="OuterCircle"
                                    Property="Fill"
                                    Value="#E8F8F0" />
                        </Trigger>

                        <!-- حالت غیرفعال -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter TargetName="OuterCircle"
                                    Property="Stroke"
                                    Value="#A9DFBF" />
                            <Setter TargetName="InnerCircle"
                                    Property="Fill"
                                    Value="#A9DFBF" />
                            <Setter Property="Foreground"
                                    Value="#A9DFBF" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
