<Window x:Class="Taadol_Cal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Taadol_Cal.Views"
        xmlns:controls="clr-namespace:Taadol_Cal.Controls"
        xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
        Title="تعادل - نرم‌افزار حسابداری"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="600"
        Background="#FFF8ED"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        WindowState="Maximized">

    <Grid ClipToBounds="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn"
                              Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- هدر -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Background="#FFF8ED"
                BorderThickness="0,0,0,1"
                Panel.ZIndex="5">
            <Grid Margin="16,15,40,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>


                <Border Grid.Column="1"
                        CornerRadius="12"
                        Width="320"
                        Height="75"
                        Background="#ffffff"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        FlowDirection="LeftToRight">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Column="0">

                            <Button Command="{Binding SaveCommand}"
                                    Background="Transparent"
                                    Foreground="#0D2159"
                                    Height="45"
                                    Width="140"
                                    Margin="11,0,11,0"
                                    Click="Button_Click_1">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                BorderBrush="#E9F0FF"
                                                BorderThickness="1"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="خروج از برنامه"
                                               FontSize="14"
                                               Margin="10,0,0,0"
                                               FontFamily="{StaticResource IRANSans}"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                    <svg:SvgViewbox Width="17"
                                                    Height="17"
                                                    Source="/Assets/Icons/direct-send.svg"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,10,0" />
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,12,0">
                            <TextBlock Text="کاربر شماره یک"
                                       FontFamily="{StaticResource IRANSans}"
                                       FontSize="16"
                                       FontWeight="DemiBold"
                                       Foreground="#0D2159" />
                            <TextBlock Text="حسابدار"
                                       FontFamily="{StaticResource IRANSans}"
                                       HorizontalAlignment="Right"
                                       FontWeight="Regular"
                                       FontSize="14"
                                       Foreground="#737791" />
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- سایدبار -->
        <controls:SidebarControl x:Name="Sidebar"
                                 Grid.Row="0"
                                 Grid.RowSpan="2"
                                 Grid.Column="0"
                                 Panel.ZIndex="10"
                                 Loaded="Sidebar_Loaded" />

        <!-- محتوا -->
        <Border x:Name="MainContentBorder"
                Grid.Row="1"
                Grid.Column="1"
                Background="#FFF8ED"
                HorizontalAlignment="Left"
                Visibility="Collapsed">

            <ContentControl x:Name="MainContent"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,16" />

        </Border>

    </Grid>
</Window>