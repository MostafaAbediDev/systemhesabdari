<UserControl x:Class="Taadol_Cal.Controls.ToggleSwitchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             FontFamily="{StaticResource IRANSans}"
             FontWeight="DemiBold"
             mc:Ignorable="d">

    <Border Background="#F1F5F9"
            CornerRadius="30"
            Padding="4"
            HorizontalAlignment="Left"
            BorderBrush="#E2E8F0"
            BorderThickness="1">

        <Grid x:Name="ToggleRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Animated Slider -->
            <Border x:Name="SliderBg"
                    BorderThickness="0.5,0.5,0.5,2"
                    BorderBrush="#22C55E"
                    CornerRadius="24"
                    Height="41"
                    Width="82"
                    Grid.Column="0"
                    Panel.ZIndex="0"
                    Background="White"
                    HorizontalAlignment="Stretch">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SliderTransform"
                                        X="0" />
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="#22C55E"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.25" />
                </Border.Effect>
            </Border>

            <!-- دکمه اتوماتیک -->
            <ToggleButton x:Name="BtnAuto"
                          Grid.Column="0"
                          IsChecked="True"
                          Panel.ZIndex="1"
                          Width="82"
                          Height="41"
                          Checked="BtnAuto_Checked"
                          Cursor="Hand">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"
                                            CornerRadius="24">
                                        <TextBlock x:Name="AutoText"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>

                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#22C55E" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                                     Value="False">
                                                            <Setter Property="Foreground"
                                                                    Value="#94A3B8" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!-- دکمه دستی -->
            <ToggleButton x:Name="BtnManual"
                          Grid.Column="1"
                          Panel.ZIndex="1"
                          Width="82"
                          Height="41"
                          Checked="BtnManual_Checked"
                          Cursor="Hand">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"
                                            CornerRadius="24">
                                        <TextBlock x:Name="ManualText"
                                                   FontSize="13"
                                                   FontWeight="DemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#94A3B8" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                                     Value="True">
                                                            <Setter Property="Foreground"
                                                                    Value="#22C55E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

        </Grid>
    </Border>
</UserControl>
