<UserControl x:Class="Taadol.Views.EditPersonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             VerticalAlignment="Stretch"
             Background="White">

    <Border x:Name="RootBorder"
            CornerRadius="12"
            ClipToBounds="True"
            Background="#ffffff"
            VerticalAlignment="Stretch"
            Margin="24,12"
            PreviewMouseLeftButtonDown="RootBorder_PreviewMouseLeftButtonDown">

        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══ ردیف ۰: هدر ═══ -->
            <Grid Grid.Row="0"
                  Margin="10,15,10,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <svg:SvgViewbox FlowDirection="LeftToRight"
                                    Width="14"
                                    Height="14"
                                    Source="/Assets/Icons/arrow-right.svg"
                                    Margin="10,0,10,0" />
                    <TextBlock Text="مشخصات شخص"
                               FontSize="18"
                               FontWeight="Bold"
                               FontFamily="{StaticResource IRANSans}"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <controls:IconButton ButtonText="ذخیره"
                                         IconSource="/Assets/Icons/edit.svg"
                                         ButtonCommand="{Binding SaveCommand}"
                                         ButtonBackground="#2667FF"
                                         Margin="0,0,8,0" />
                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Width="36"
                            Height="36"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center">
                        <svg:SvgViewbox Width="16" Height="16"
                                        Source="/Assets/Icons/close.svg"
                                        FlowDirection="LeftToRight" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- خط جداکننده دش‌دار -->
            <Border Grid.Row="0"
                    Height="1"
                    Margin="7,0,7,2"
                    VerticalAlignment="Bottom">
                <Border.Background>
                    <VisualBrush TileMode="Tile"
                                 Viewport="0,0,10,1"
                                 ViewportUnits="Absolute"
                                 Viewbox="0,0,10,1"
                                 ViewboxUnits="Absolute">
                        <VisualBrush.Visual>
                            <Grid Width="10"
                                  Height="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="5" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0"
                                           Fill="#D4E0FF" />
                                <Rectangle Grid.Column="1"
                                           Fill="#D4E0FF" />
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.Background>
            </Border>

            <!-- ═══ ردیف ۱: CardPanel اصلی (اطلاعات شخص) ═══ -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="شناسه یکتا"
                                       Style="{StaticResource FormLabel}" />
                        </StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <controls:ModernPersianTextBox Grid.Column="0"
                                                           x:Name="ManualCodeTextBox"
                                                           Text="{Binding ManualCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsEnabled="False"
                                                           Placeholder="1234" />
                            <controls:ToggleSwitchControl x:Name="CodeModeToggle"
                                                          Margin="12,0,0,0"
                                                          FirstLabel="اتوماتیک"
                                                          SecondLabel="دستی"
                                                          IsFirstSelected="True"
                                                          Grid.Column="1"
                                                          SelectionChanged="CodeModeToggle_SelectionChanged" />
                        </Grid>

                        <TextBlock Text="انتخاب شعبه"
                                   Style="{StaticResource FormLabel}" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Grid Width="315">
                                <ComboBox x:Name="BranchCombo"
                                          Style="{StaticResource SearchableComboBox}"
                                          Tag="جستجو..."
                                          Width="315"
                                          ItemsSource="{Binding Branches}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedBranchId, Mode=TwoWay}"
                                          ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                            </Grid>
                        </StackPanel>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition MaxHeight="625" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="نوع شخص"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ToggleSwitchControl x:Name="LegalTypeToggle"
                                                              FirstLabel="حقیقی"
                                                              SecondLabel="حقوقی"
                                                              IsFirstSelected="True"
                                                              Grid.Column="1"
                                                              Margin="9,0,0,0"
                                                              SelectionChanged="LegalTypeToggle_SelectionChanged" />
                                <ToggleButton x:Name="PersonActiveToggle"
                                              Content=".شخص فعال است"
                                              FlowDirection="LeftToRight"
                                              Style="{StaticResource StatusToggleButton}"
                                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                                              Margin="10,0,18,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,5,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        x:Name="FirstNamePanel">
                                <TextBlock Text="نام"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="علی" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        x:Name="LastNamePanel">
                                <TextBlock Text="نام خانوادگی"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="علوی" />
                            </StackPanel>
                            <StackPanel Grid.Column="4"
                                        x:Name="NationalCodePanel">
                                <TextBlock Text="کد ملی"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                               Text="{Binding NationalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="2470545256" />
                            </StackPanel>

                            <StackPanel Grid.Column="0"
                                        x:Name="CompanyNamePanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="نام شرکت"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="شرکت نمونه" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        x:Name="EconomicCodePanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="کد اقتصادی"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                               Text="{Binding EconomicCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="123456789" />
                            </StackPanel>
                            <StackPanel Grid.Column="4"
                                        x:Name="RegistrationNumberPanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="شماره ثبت"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                               Text="{Binding RegistrationNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="12345" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="ContactPersonPanel"
                              Margin="0,5,0,4"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="نام فرد رابط"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding ContactFirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="علی" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="نام خانوادگی فرد رابط"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding ContactLastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="رضایی" />
                            </StackPanel>
                        </Grid>

                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="55" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Margin="0,0,0,5"
                                               Text="دسته کلی"
                                               Style="{StaticResource FormLabel}"
                                               VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal"
                                                Grid.Row="1">
                                        <ToggleButton x:Name="PersonTypeCustomer"
                                                      Content="مشتری"
                                                      Tag="1"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton x:Name="PersonTypeSupplier"
                                                      Content="تامین کننده"
                                                      Tag="3"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton x:Name="PersonTypeBoth"
                                                      Content="هردو"
                                                      Tag="1"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton x:Name="PersonTypePersonnel"
                                                      Content="پرسنل"
                                                      Tag="2"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Unchecked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <controls:CategorySearchControl x:Name="CategorySearch"
                                                                Width="350"
                                                                MainIconSource="/Assets/Icons/custom_icon.svg" />
                            </StackPanel>
                        </Grid>

                    </StackPanel>

                    <!-- تصویر -->
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                        <controls:ImagePickerControl ImageSelected="OnImageSelected"
                                                     ImageRemoved="OnImageRemoved"
                                                     Loaded="ImagePickerControl_Loaded" />
                    </StackPanel>
                </Grid>
            </Border>

<!-- ═══ ردیف ۲: جداکننده دکمه‌ای ═══ -->
            <Grid Grid.Row="2"
                  Margin="0,0,0,2">
                <Border Height="3">
                    <Border.Background>
                        <VisualBrush TileMode="Tile"
                                     Viewport="0,0,10,1"
                                     ViewportUnits="Absolute"
                                     Viewbox="0,0,10,1"
                                     ViewboxUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="10"
                                      Height="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="5" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Fill="#BED1FF" />
                                    <Rectangle Grid.Column="1"
                                               Fill="Transparent" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>
                <Ellipse Width="17"
                         Margin="-9,0,0,0"
                         Height="25"
                         Fill="#FFF8ED"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Panel.ZIndex="2" />
                <Ellipse Width="17"
                         Height="25"
                         Margin="0,0,-9,0"
                         Fill="#FFF8ED"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Panel.ZIndex="2" />
            </Grid>

            <!-- ═══ ردیف ۳: محتوای کامل (یک تکه، با اسکرول) ═══ -->
            <ScrollViewer Grid.Row="3"
                          Style="{StaticResource MinimalScrollViewer}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ═══ بخش تماس و آدرس ═══ -->
                    <Border Style="{StaticResource CardPanel}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="تماس و آدرس"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       FontFamily="{StaticResource IRANSans}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="شماره تلفن"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="071" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="استان"
                                                       Style="{StaticResource FormLabel}" />
                                            <ComboBox x:Name="ProvinceCombo"
                                                      Style="{StaticResource SearchableComboBox}"
                                                      Tag="جستجو"
                                                      Width="200"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding Provinces}"
                                                      DisplayMemberPath="Title"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedProvinceId, Mode=TwoWay}"
                                                      ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="کد پستی"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           Text="{Binding PostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="موبایل"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Mobile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="0912" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="شهرستان"
                                                       Style="{StaticResource FormLabel}" />
                                            <ComboBox x:Name="CityCombo"
                                                      Style="{StaticResource SearchableComboBox}"
                                                      Tag="جستجو..."
                                                      Width="200"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding Cities}"
                                                      DisplayMemberPath="Title"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedCityId, Mode=TwoWay}"
                                                      ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="ایمیل"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="example@mail.com" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel>
                                        <TextBlock Text="آدرس"
                                                   Style="{StaticResource FormLabel}"
                                                   Margin="0,0,0,8" />
                                        <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernPersianTextBox}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Height="80"
                                                 VerticalAlignment="Top"
                                                 materialDesign:HintAssist.Hint="آدرس را وارد کنید..." />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══ جداکننده ═══ -->
                    <Border Height="3"
                            Margin="0,0,0,12">
                        <Border.Background>
                            <VisualBrush TileMode="Tile"
                                         Viewport="0,0,10,1"
                                         ViewportUnits="Absolute"
                                         Viewbox="0,0,10,1"
                                         ViewboxUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Grid Width="10"
                                          Height="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="5" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0"
                                                   Fill="#BED1FF" />
                                        <Rectangle Grid.Column="1"
                                                   Fill="Transparent" />
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.Background>
                    </Border>

                    <!-- ═══ بخش حساب‌های بانکی ═══ -->
                    <Border Style="{StaticResource CardPanel}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="حساب‌های بانکی"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       FontFamily="{StaticResource IRANSans}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,10"
                                  HorizontalAlignment="Left"
                                  MaxWidth="700">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="نام بانک اصلی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="200"
                                                                   Text="{Binding MainBankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="ملت" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="شعبه"
                                               Style="{StaticResource FormLabel}" />
                                    <ComboBox x:Name="BankBranchCombo"
                                              Style="{StaticResource SearchableComboBox}"
                                              Tag="جستجو..."
                                              Width="200"
                                              ItemsSource="{Binding BankBranches}"
                                              DisplayMemberPath="BranchName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedBankBranchId, Mode=TwoWay}"
                                              ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="15,0,0,0">
                                    <ToggleButton Content="حساب پیش فرض"
                                                  FlowDirection="LeftToRight"
                                                  Style="{StaticResource StatusToggleButton}"
                                                  IsChecked="{Binding MainBankIsDefault, Mode=TwoWay}"
                                                  Margin="0,0,10,0" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10"
                                  HorizontalAlignment="Left"
                                  MaxWidth="700">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="شماره کارت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="200"
                                                                   FlowDirection="LeftToRight"
                                                                   Text="{Binding MainCardNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="**** **** **** ****" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="شماره شبا"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="200"
                                                                   FlowDirection="LeftToRight"
                                                                   Text="{Binding MainShaba, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="IR" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="شماره حساب"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="200"
                                                                   FlowDirection="LeftToRight"
                                                                   Text="{Binding MainAccountNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="456" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,8"
                                  HorizontalAlignment="Left"
                                  MaxWidth="700">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Button x:Name="AddBankAccountButton"
                                            Content="افزودن حساب جدید"
                                            Margin="0,0,8,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
