<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    
    <Style x:Key="SubmenuWrapper"
           TargetType="Grid">
        <Setter Property="Background"
                Value="Transparent" />
    </Style>

    
    <Style x:Key="SubmenuBackground"
           TargetType="Border">
        <Setter Property="Background"
                Value="#E9F0FF" />
        <Setter Property="CornerRadius"
                Value="0,0,8,8" />
        <Setter Property="Padding"
                Value="0,8" />
        <Setter Property="Margin"
                Value="10,0,10,0" />
    </Style>

    
    <Style x:Key="SubmenuDivider"
           TargetType="Border">
        <Setter Property="Height"
                Value="1" />
        <Setter Property="Margin"
                Value="10,9,10,6" />
        <Setter Property="Background">
            <Setter.Value>
                <VisualBrush TileMode="Tile"
                             Viewport="0,0,8,1"
                             ViewportUnits="Absolute"
                             Viewbox="0,0,8,1"
                             ViewboxUnits="Absolute">
                    <VisualBrush.Visual>
                        <Grid Width="8"
                              Height="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="4" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0"
                                       Fill="#2667FF" />
                            <Rectangle Grid.Column="1"
                                       Fill="Transparent" />
                        </Grid>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Setter.Value>
        </Setter>
    </Style>

    
    <Style x:Key="SubmenuEllipseLeft"
           TargetType="Ellipse">
        <Setter Property="Width"
                Value="17" />
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Fill"
                Value="#F8FAFF" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="0,5,0,0" />
        <Setter Property="Panel.ZIndex"
                Value="2" />
    </Style>

    
    <Style x:Key="SubmenuEllipseRight"
           TargetType="Ellipse">
        <Setter Property="Width"
                Value="17" />
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Fill"
                Value="#F8FAFF" />
        <Setter Property="HorizontalAlignment"
                Value="Right" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="0,5,0,0" />
        <Setter Property="Panel.ZIndex"
                Value="2" />
    </Style>

    
    <Style x:Key="SubmenuItem"
           TargetType="Button">
        <Setter Property="Height"
                Value="36" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="Transparent"
                            Margin="20,1,12,1"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <TextBlock Text="•"
                                       FontSize="16"
                                       Foreground="#0D2159"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <ContentPresenter VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize"
                                                Value="14" />
                                        <Setter Property="FontWeight"
                                                Value="Regular" />
                                        <Setter Property="Foreground"
                                                Value="#0D2159" />
                                        <Setter Property="FontFamily"
                                                Value="{StaticResource IRANSans}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
