<UserControl x:Class="Taadol.Views.CompanyListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Taadol.Views"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
        
             Padding="0"
             FontFamily="{StaticResource IRANSans}"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="FilterTabStyle2"
               TargetType="RadioButton">
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Width"
                    Value="215" />
            <Setter Property="Foreground"
                    Value="#2563EB" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="16,10" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Border x:Name="CheckBoxBorder"
                                            Width="20"
                                            Height="20"
                                            BorderThickness="2"
                                            BorderBrush="#2ECC71"
                                            CornerRadius="4"
                                            Background="White"
                                            Padding="2"
                                            Margin="0,0,6,0"
                                            Visibility="Collapsed">
                                        <svg:SvgViewbox x:Name="CheckMark"
                                                        Width="8"
                                                        Height="8"
                                                        Source="/Assets/Icons/Line.svg"
                                                        FlowDirection="LeftToRight"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock x:Name="TitleText"
                                               Text="{TemplateBinding Content}"
                                               Foreground="#2563EB"
                                               FontWeight="Medium" />
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           x:Name="CountText"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#94A3B8"
                                           FontWeight="Normal"
                                           HorizontalAlignment="Left" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="#2563EB" />
                                <Setter TargetName="Root"
                                        Property="BorderThickness"
                                        Value="1" />

                                <Setter TargetName="TitleText"
                                        Property="Foreground"
                                        Value="#2563EB" />
                                <Setter TargetName="TitleText"
                                        Property="FontWeight"
                                        Value="Bold" />
                                <Setter TargetName="CountText"
                                        Property="Foreground"
                                        Value="#64748B" />

                                <Setter TargetName="CheckBoxBorder"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsChecked"
                                     Value="False">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="#E9F0FF" />
                                <Setter TargetName="Root"
                                        Property="BorderThickness"
                                        Value="1" />

                                <Setter TargetName="TitleText"
                                        Property="Foreground"
                                        Value="#2563EB" />
                                <Setter TargetName="TitleText"
                                        Property="FontWeight"
                                        Value="Bold" />
                                <Setter TargetName="CountText"
                                        Property="Foreground"
                                        Value="#64748B" />
                            </Trigger>

                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#F4F7FF" />
                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="TitleText"
                                        Property="Foreground"
                                        Value="#CBD5E1" />
                                <Setter TargetName="CountText"
                                        Property="Foreground"
                                        Value="#E2E8F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Margin="0"
            Background="White"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="0,12"
                    Background="White"
                    CornerRadius="12,12,0,0"
                    ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="16"
                                        Height="16"
                                        Source="/Assets/Icons/arrow-right.svg"
                                        Margin="10,0,10,0" />

                        <TextBlock Text="لیست شرکت‌ها"
                                   FontSize="19"
                                   FontFamily="{StaticResource IRANSans}"
                                   FontWeight="Bold"
                                   Foreground="#001242"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="RightToLeft">
                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnMore_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/MORE.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnDelete_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/trash.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#FEF2F2" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnEdit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/EDIT.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnNew_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/plus.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0FFF4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="#D4E0FF"
                    BorderThickness="0,2,0,0"
                    Background="#FAFCFF"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal"
                            FlowDirection="RightToLeft"
                            VerticalAlignment="Center">
                    <RadioButton x:Name="tabAll"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="CompanyFilter"
                                 Content="همه شرکت‌ها"
                                 Tag="همه"
                                 IsChecked="True"
                                 Checked="FilterTab_Checked" />

                    <RadioButton x:Name="tabActive"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="CompanyFilter"
                                 Content="فعال"
                                 Tag="فعال"
                                 Checked="FilterTab_Checked" />

                    <RadioButton x:Name="tabInactive"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="CompanyFilter"
                                 Content="غیرفعال"
                                 Tag="غیرفعال"
                                 Checked="FilterTab_Checked" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="Transparent"
                    CornerRadius="12"
                    ClipToBounds="False"
                    Padding="15,0">
                
                <Grid x:Name="DataGridContainer">
                    <Grid.Resources>
                        <Style x:Key="EllipseLeft"
                               TargetType="Ellipse">
                            <Setter Property="Width"
                                    Value="25" />
                            <Setter Property="Height"
                                    Value="35" />
                            <Setter Property="Fill"
                                    Value="#FFF8ED" />
                            <Setter Property="HorizontalAlignment"
                                    Value="Left" />
                            <Setter Property="VerticalAlignment"
                                    Value="Center" />
                            <Setter Property="Margin"
                                    Value="-31,0,0,0" />
                            <Setter Property="Panel.ZIndex"
                                    Value="-1" />
                        </Style>

                        <Style x:Key="EllipseRight"
                               TargetType="Ellipse">
                            <Setter Property="Width" 
                                    Value="25" />
                            <Setter Property="Height"
                                    Value="35" />
                            <Setter Property="Fill"
                                    Value="#FFF8ED" />
                            <Setter Property="HorizontalAlignment"
                                    Value="Right" />
                            <Setter Property="VerticalAlignment"
                                    Value="Center" />
                            <Setter Property="Margin"
                                    Value="0,0,-31,0" />
                            <Setter Property="Panel.ZIndex"
                                    Value="-1" />
                        </Style>
                    </Grid.Resources>
                    <DataGrid x:Name="CompaniesDataGrid"
                              BorderThickness="0"
                              Background="White"
                              CanUserSortColumns="False"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              VerticalGridLinesBrush="#CCD0D9"
                              HorizontalGridLinesBrush="#CCD0D9"
                             
                              RowHeight="30"
                              SnapsToDevicePixels="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              AlternationCount="2"
                              IsReadOnly="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              FontFamily="{StaticResource IRANSans}"
                              SelectionChanged="CompaniesDataGrid_SelectionChanged">
                        <DataGrid.Resources>
                            <Style x:Key="BaseTextColumnStyle"
                                   TargetType="TextBlock">
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                                <Setter Property="VerticalAlignment"
                                        Value="Center" />
                                <Setter Property="Foreground"
                                        Value="#5C5C5C" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                            </Style>

                            <Style x:Key="LtrTextColumnStyle"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource BaseTextColumnStyle}">
                                <Setter Property="FlowDirection"
                                        Value="LeftToRight" />
                            </Style>

                            <Style x:Key="RowNumberColumnStyle"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource BaseTextColumnStyle}">
                                <Setter Property="Foreground"
                                        Value="#94A3B8" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Style>

                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Tag"
                                        Value="True" />
                                <Setter Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#0D2159" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                                <Setter Property="Padding"
                                        Value="10,0" />
                                <Setter Property="BorderBrush"
                                        Value="#BED1FF" />
                                <Setter Property="BorderThickness"
                                        Value="1,2,1,2" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                                <Setter Property="Height"
                                        Value="46" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <ContentPresenter Grid.Column="0"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center" />

                                                    <svg:SvgViewbox x:Name="FilterIcon"
                                                                    Width="13"
                                                                    Height="13"
                                                                    Grid.Column="1"
                                                                    Source="/Assets/Icons/filter-search.svg"
                                                                    VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Tag"
                                                         Value="False">
                                                    <Setter TargetName="FilterIcon"
                                                            Property="Visibility"
                                                            Value="Collapsed" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#5C5C5C" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                                <Setter Property="Padding"
                                        Value="8,0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E8F2FF" />
                                        <Setter Property="Foreground"
                                                Value="#2667FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="Background"
                                        Value="#FFFFFF" />
                                <Setter Property="Cursor"
                                        Value="Hand" />

                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex"
                                             Value="1">
                                        <Setter Property="Background"
                                                Value="#E5E7EC" />
                                    </Trigger>

                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#F0F5FF" />
                                    </Trigger>

                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E8F2FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header=""
                                                    Width="60">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Center" />
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>

                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="CheckBoxBorder"
                                                Width="22"
                                                Height="22"
                                                BorderThickness="2"
                                                CornerRadius="4"
                                                Cursor="Hand"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                MouseLeftButtonUp="CheckBoxBorder_MouseLeftButtonUp">

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="White" />
                                                    <Setter Property="BorderBrush"
                                                            Value="#CBD5E1" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}"
                                                                     Value="True">
                                                            <Setter Property="Background"
                                                                    Value="White" />
                                                            <Setter Property="BorderBrush"
                                                                    Value="#2ECC71" />
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IsEmpty}"
                                                                     Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>

                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#F0F5FF" />
                                                            <Setter Property="BorderBrush"
                                                                    Value="#2ECC71" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <svg:SvgViewbox x:Name="CheckMark"
                                                            Width="10"
                                                            Height="10"
                                                            Source="/Assets/Icons/Line.svg"
                                                            FlowDirection="LeftToRight"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                <svg:SvgViewbox.Style>
                                                    <Style TargetType="svg:SvgViewbox">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}"
                                                                         Value="True">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </svg:SvgViewbox.Style>
                                            </svg:SvgViewbox>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="#"
                                                Width="50"
                                                Binding="{Binding RowNumberDisplay}"
                                                ElementStyle="{StaticResource RowNumberColumnStyle}">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                        

                       

                            <DataGridTextColumn Header="عنوان شرکت"
                                                Width="220"
                                                Binding="{Binding Title}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTextColumn Header="نام حقوقی"
                                                Width="260"
                                                Binding="{Binding LegalName}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTemplateColumn Header="وضعیت"
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,3"
                                                CornerRadius="5"
                                                HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="فعال">
                                                            <Setter Property="Background"
                                                                    Value="#DCFCE7" />
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="غیرفعال">
                                                            <Setter Property="Background"
                                                                    Value="#FEE2E2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       FontFamily="{StaticResource IRANSans}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="فعال">
                                                                <Setter Property="Foreground"
                                                                        Value="#166534" />
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="غیرفعال">
                                                                <Setter Property="Foreground"
                                                                        Value="#991B1B" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="تاریخ ثبت"
                                                Width="120"
                                                Binding="{Binding RegisterDate}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Ellipse Style="{StaticResource EllipseLeft}" />
                    <Ellipse Style="{StaticResource EllipseRight}" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Padding="5,14"
                    Background="White"
                    BorderBrush="#E9F0FF"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="LeftToRight">
                        <Button Width="34"
                                Height="34"
                                Margin="0,0,2,0"
                                Cursor="Hand"
                                Click="BtnPrevPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30"
                                            Background="Transparent">
                                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                                        Width="30"
                                                        Height="30"
                                                        Source="/Assets/Icons/Leftsquare.svg" />
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <ItemsControl x:Name="PageButtonsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="32"
                                            Height="32"
                                            Cursor="Hand"
                                            Click="BtnPage_Click"
                                            Tag="{Binding PageNumber}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd"
                                                        Background="Transparent"
                                                        CornerRadius="6">
                                                    <TextBlock Text="{Binding PageNumberDisplay}"
                                                               FontSize="13"
                                                               FontFamily="{StaticResource IRANSans}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground"
                                                                        Value="#94A3B8" />
                                                                <Setter Property="FontWeight"
                                                                        Value="Normal" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrent}"
                                                                                 Value="True">
                                                                        <Setter Property="Foreground"
                                                                                Value="#001242" />
                                                                        <Setter Property="FontWeight"
                                                                                Value="Bold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="bd"
                                                                Property="Background"
                                                                Value="#F5F7FA" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Width="34"
                                Height="34"
                                Margin="2,0,0,0"
                                Cursor="Hand"
                                Click="BtnNextPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30"
                                            Background="Transparent">
                                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                                        Width="30"
                                                        Height="30"
                                                        Source="/Assets/Icons/Rightsquare.svg" />
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>