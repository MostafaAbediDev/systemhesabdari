<UserControl x:Class="Taadol.Views.NewFinancialPeriodView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Taadol.ViewModels"
             xmlns:controls="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Border CornerRadius="12"
                ClipToBounds="True"
                Background="#ffffff"
                Margin="24,0">
            <StackPanel>

                
                <Grid Margin="10,15,10,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="14"
                                        Height="14"
                                        Source="/Assets/Icons/arrow-right.svg"
                                        Margin="10,0,10,0" />
                        <TextBlock Text="مشخصات دوره مالی"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource IRANSans}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">

                        <controls:CustomOutlinedButton Margin="0,0,12,0"
                                                       Text="ثبت موقت">
                            <controls:CustomOutlinedButton.Icon>
                                <svg:SvgViewbox Source="/Assets/Icons/tempsave.svg"
                                                Width="16"
                                                Height="16" />
                            </controls:CustomOutlinedButton.Icon>
                        </controls:CustomOutlinedButton>

                        <controls:IconButton ButtonText="ثبت"
                                             IconSource="/Assets/Icons/save.svg"
                                             ButtonCommand="{Binding SaveCommand}"
                                             ButtonBackground="#2667FF" />
                    </StackPanel>
                </Grid>

                
                <Border Height="1"
                        Margin="7,0,7,2">
                    <Border.Background>
                        <VisualBrush TileMode="Tile"
                                     Viewport="0,0,10,1"
                                     ViewportUnits="Absolute"
                                     Viewbox="0,0,10,1"
                                     ViewboxUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="10"
                                      Height="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="5" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Fill="#D4E0FF" />
                                    <Rectangle Grid.Column="1"
                                               Fill="#D4E0FF" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>
                
                
                
                
                
                
                
                
                
                
                
                
                
                
                

                
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>

                        
                        <TextBlock Text="عنوان دوره مالی"
                                   Style="{StaticResource FormLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                        <controls:ModernPersianTextBox Text="{Binding PeriodTitle, UpdateSourceTrigger=PropertyChanged}"
                                                       Placeholder="دوره اول"
                                                       Grid.Column="0"
                                                       Margin="0,0,0,16" />
                        </Grid>

                        
                        <TextBlock Text="انتخاب شعبه"
                                   Style="{StaticResource FormLabel}" />
                        <ComboBox Style="{StaticResource SearchableComboBox}"
                                  Tag="جستجو"
                                  Width="330"
                                  HorizontalAlignment="Left"
                                  ItemContainerStyle="{StaticResource SearchableComboBoxItem}"
                                  Margin="0,0,0,16"
                                  SelectionChanged="ComboBox_SelectionChanged">
                            <ComboBoxItem Content="شعبه مرکزی" />
                            <ComboBoxItem Content="شعبه شمال" />
                            <ComboBoxItem Content="شعبه جنوب" />
                        </ComboBox>

                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="تاریخ شروع دوره"
                                           Style="{StaticResource FormLabel}" />
                                <controls:PersianDatePickerControl x:Name="StartDatePicker"
                                                                   SelectedDate="{Binding StartDate}"
                                                                   DateChanged="DatePicker_DateChanged" />
                            </StackPanel>

                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="تاریخ پایان دوره"
                                           Style="{StaticResource FormLabel}" />
                                <controls:PersianDatePickerControl x:Name="EndDatePicker"
                                                                   SelectedDate="{Binding EndDate}"
                                                                   DateChanged="DatePicker_DateChanged" />
                            </StackPanel>
                        </Grid>

                        
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4,0,0">
                            <ToggleButton Content=".دوره مال جاری است"
                                          FlowDirection="LeftToRight"
                                          Style="{StaticResource StatusToggleButton}"
                                          IsChecked="True"
                                          Margin="10,0,18,0" /> 
                        </StackPanel>
                        <Grid Margin="0,2,0,5">
                            <!--<Border Height="3">
                                <Border.Background>
                                    <VisualBrush TileMode="Tile"
                                                 Viewport="0,0,10,1"
                                                 ViewportUnits="Absolute"
                                                 Viewbox="0,0,10,1"
                                                 ViewboxUnits="Absolute">
                                        <VisualBrush.Visual>
                                            <Grid Width="10"
                                                  Height="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="5" />
                                                    <ColumnDefinition Width="5" />
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0"
                                                           Fill="#BED1FF" />
                                                <Rectangle Grid.Column="1"
                                                           Fill="Transparent" />
                                            </Grid>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.Background>
                            </Border>-->

                            <Ellipse Width="17"
                                     Margin="-20,0,0,0"
                                     Height="25"
                                     Fill="#FFF8ED"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Panel.ZIndex="2" />

                            <Ellipse Width="17"
                                     Height="25"
                                     Margin="0,0,-15,0"
                                     Fill="#FFF8ED"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Panel.ZIndex="2" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
