<UserControl x:Class="Taadol.Views.NewBranchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Taadol.ViewModels"
             xmlns:controls="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             Background="Transparent">


    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Border  CornerRadius="12"
                 ClipToBounds="True"
                 Background="#ffffff"
                 Margin="24,0">
            <StackPanel>


                <Grid Margin="10,15,10,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="14"
                                        Height="14"
                                        Source="/Assets/Icons/arrow-right.svg"
                                        Margin="10,0,10,0" />
                        <TextBlock Text="مشخصات شعبه جدید"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource IRANSans}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">

                        <controls:CustomOutlinedButton Margin="0,0,12,0"
                                                       Text="ثبت موقت">
                            <controls:CustomOutlinedButton.Icon>
                                <svg:SvgViewbox  Source="/Assets/Icons/tempsave.svg"
                                                 Width="16"
                                                 Height="16" />
                            </controls:CustomOutlinedButton.Icon>
                        </controls:CustomOutlinedButton>

                        <controls:IconButton ButtonText="ثبت"
                                             IconSource="/Assets/Icons/save.svg"
                                             ButtonCommand="{Binding SaveCommand}"
                                             ButtonBackground="#2667FF" />

                    </StackPanel>
                </Grid>
                <Border Height="1"
                        Margin="7,0,7,2">
                    <Border.Background>
                        <VisualBrush TileMode="Tile"
                                     Viewport="0,0,10,1"
                                     ViewportUnits="Absolute"
                                     Viewbox="0,0,10,1"
                                     ViewboxUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="10"
                                      Height="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="5" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Fill="#D4E0FF" />
                                    <Rectangle Grid.Column="1"
                                               Fill="#D4E0FF" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>

                <Border  Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,24,0">


                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="شناسه یکتا"
                                           Style="{StaticResource FormLabel}" />

                            </StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <controls:ModernPersianTextBox Grid.Column="0"
                                                               Text="{Binding UniqueCode, UpdateSourceTrigger=PropertyChanged}"
                                                               InputType="Number"
                                                               FlowDirection="LeftToRight"
                                                               Placeholder="1234"
                                                               IsEnabled="{Binding IsUniqueCodeManual}" />

                                <!--<TextBox Grid.Column="0"
                                         Text="{Binding CurrentProduct.AccountCode, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernPersianTextBox}"
                                         FontFamily="{StaticResource IRANSans}"
                                  
                                       />-->
                                <controls:ToggleSwitchControl Margin="12,0,0,0"
                                                              FirstLabel="اتوماتیک"
                                                              SecondLabel="دستی"
                                                              IsFirstSelected="True"
                                                              Grid.Column="1"
                                                              SelectionChanged="UniqueCodeMode_SelectionChanged" />
                                <!--<controls:ToggleRadioControl CheckedLabel="فعال"
                                                             UncheckedLabel="غیرفعال"
                                                             FlowDirection="LeftToRight"
                                                             Grid.Column="2"
                                                             Margin="12,0,0,0"
                                                             IsChecked="False"
                                                             Checked="Radio_Checked" />-->

                            </Grid>

                            <TextBlock Text="نام شرکت"
                                       Style="{StaticResource FormLabel}" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <Grid Width="315">
                                    <ComboBox x:Name="CompanyComboBox"
                                              Style="{StaticResource SearchableComboBox}"
                                              Tag="جستجوی شرکت"
                                              Width="315"
                                              ItemsSource="{Binding Companies}"
                                              DisplayMemberPath="Title"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedCompanyId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />

                                    <!-- لودینگ روی قسمت فلش کمبو -->
                                    <Border x:Name="CompanyComboLoading"
                                            Width="42"
                                            Height="42"
                                            Background="White"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False"
                                            CornerRadius="8">

                                        <Grid Width="22"
                                              Height="22"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">

                                            <Grid.RenderTransform>
                                                <RotateTransform x:Name="CompanyComboSpinnerRotate"
                                                                 Angle="0" />
                                            </Grid.RenderTransform>

                                            <Ellipse Width="20"
                                                     Height="20"
                                                     Stroke="#D4E0FF"
                                                     StrokeThickness="3" />

                                            <Path Stroke="#2667FF"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Data="M 11,1 A 10,10 0 0 1 21,11" />

                                            <Grid.Triggers>
                                                <EventTrigger RoutedEvent="Grid.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetName="CompanyComboSpinnerRotate"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             From="0"
                                                                             To="360"
                                                                             Duration="0:0:0.8" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Grid.Triggers>
                                        </Grid>
                                    </Border>
                                </Grid>

                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MaxWidth="625" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Visibility="Collapsed">
                                    <TextBlock Text="نام شرکت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Grid.Column="0"
                                                                   Width="620"
                                                                   Text="{Binding Username}"
                                                                   Placeholder="بنویسید" />
                                </StackPanel>
                            </Grid>

                            <Grid>

                                <Grid.RowDefinitions>
                                    <RowDefinition MaxHeight="625" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="نوع شعبه"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ToggleSwitchControl FirstLabel="اصلی"
                                                                  SecondLabel="فرعی"
                                                                  IsFirstSelected="True"
                                                                  Grid.Column="1"
                                                                  Margin="9,0,0,0"
                                                                  SelectionChanged="BranchTypeToggle_SelectionChanged" />
                                    <ToggleButton Content="شعبه فعال است"
                                                  FlowDirection="LeftToRight"
                                                  Style="{StaticResource StatusToggleButton}"
                                                  IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="10,0,18,0" />
                                </StackPanel>
                            </Grid>


                            <Grid Margin="0,5,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1.5*" />
                                  
                                </Grid.ColumnDefinitions>

                                
                                <StackPanel Grid.Column="0"
                                            x:Name="FirstNamePanel">
                                    <TextBlock Text="نام شعبه"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding BranchName, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="شعبه مرکزی" />
                                </StackPanel>

                              

                                
                                <StackPanel Grid.Column="0"
                                            x:Name="CompanyNamePanel"
                                            Visibility="Collapsed">
                                    <TextBlock Text="نام شرکت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding CompanyName}"
                                                                   Placeholder="شرکت نمونه" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            x:Name="EconomicCodePanel"
                                            Visibility="Collapsed">
                                    <TextBlock Text="کد اقتصادی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                                   Text="{Binding EconomicCode}"
                                                                   Placeholder="123456789" />
                                </StackPanel>

                                <StackPanel Grid.Column="4"
                                            x:Name="RegistrationNumberPanel"
                                            Visibility="Collapsed">
                                    <TextBlock Text="شماره ثبت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                                   Text="{Binding RegistrationNumber}"
                                                                   Placeholder="12345" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1.5*" />
                                    
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1.5*" />
                                    
                                </Grid.ColumnDefinitions>

                                
                                <StackPanel Grid.Column="0"
                                           >
                                    <TextBlock Text="کد اقتصادی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding EconomicCode, UpdateSourceTrigger=PropertyChanged}"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="247000" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                         >
                                    <TextBlock Text="شماره ثبت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding RegisterNumber, UpdateSourceTrigger=PropertyChanged}"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="2480" />
                                </StackPanel>

                              
                                
                                <StackPanel Grid.Column="0"
                                          
                                            Visibility="Collapsed">
                                    <TextBlock Text="نام شرکت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding CompanyName}"
                                                                   Placeholder="شرکت نمونه" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                        
                                            Visibility="Collapsed">
                                    <TextBlock Text="کد اقتصادی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                                   Text="{Binding EconomicCode}"
                                                                   Placeholder="123456789" />
                                </StackPanel>

                                <StackPanel Grid.Column="4"
                                          
                                            Visibility="Collapsed">
                                    <TextBlock Text="شماره ثبت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                                   Text="{Binding RegistrationNumber}"
                                                                   Placeholder="12345" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,5,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1.5*" />
                                    
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1.5*" />
                                    
                                </Grid.ColumnDefinitions>

                                
                                <StackPanel Grid.Column="0"
                                           >
                                    <TextBlock Text="کد شعبه"
                                               Style="{StaticResource FormLabel}" />

                                    <controls:ModernPersianTextBox Text="{Binding BranchCode, UpdateSourceTrigger=PropertyChanged}"
                                                                   InputType="Number"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="کد شعبه" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                         >
                                    <TextBlock Text="شناسه ملی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}"
                                                                   InputType="Number"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="شناسه ملی را وارد کنید" />
                                </StackPanel>

                              
                                
                                <StackPanel Grid.Column="0"
                                          
                                            Visibility="Collapsed">
                                    <TextBlock Text="نام شرکت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding CompanyName}"
                                                                   Placeholder="شرکت نمونه" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                        
                                            Visibility="Collapsed">
                                    <TextBlock Text="کد اقتصادی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                                   Text="{Binding EconomicCode}"
                                                                   Placeholder="123456789" />
                                </StackPanel>

                                <StackPanel Grid.Column="4"
                                          
                                            Visibility="Collapsed">
                                    <TextBlock Text="شماره ثبت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                                   Text="{Binding RegistrationNumber}"
                                                                   Placeholder="12345" />
                                </StackPanel>
                            </Grid>
                            <!--<TextBlock HorizontalAlignment="Center"
                                       Text="بارکدهای مختلف را با ; از هم جدا کنید."
                                       FontSize="12"
                                       Foreground="#001242"
                                       Margin="0,0,180,5" />-->


                 



                        </StackPanel>


                       
                    </Grid>
                </Border>


                <Grid Margin="0,0,0,2">
                    <Border Height="3">
                        <Border.Background>
                            <VisualBrush TileMode="Tile"
                                         Viewport="0,0,10,1"
                                         ViewportUnits="Absolute"
                                         Viewbox="0,0,10,1"
                                         ViewboxUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Grid Width="10"
                                          Height="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="5" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0"
                                                   Fill="#BED1FF" />
                                        <Rectangle Grid.Column="1"
                                                   Fill="Transparent" />
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.Background>
                    </Border>


                    <Ellipse Width="17"
                             Margin="-9,0,0,0"
                             Height="25"
                             Fill="#FFF8ED"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Panel.ZIndex="2" />


                    <Ellipse Width="17"
                             Height="25"
                             Margin="0,0,-9,0"
                             Fill="#FFF8ED"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Panel.ZIndex="2" />
                </Grid>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="20,0,0,0"
                                HorizontalAlignment="Left"
                                Grid.Row="0">


                        <Border CornerRadius="12"
                                BorderThickness="1.5"
                                BorderBrush="#BED1FF"
                                Background="#F8FAFF"
                                Padding="4"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="تماس"
                                              Style="{StaticResource ModernTabButton}"
                                              Margin="10,0,6,0"
                                              IsChecked="True"
                                              x:Name="TabPricing"
                                              Checked="TabPricing_Checked" />
                                <RadioButton Content="آدرس"
                                              Style="{StaticResource ModernTabButton}"
                                              Margin="10,0,6,0"
                                              x:Name="TabInventory"
                                              Checked="TabInventory_Checked" />
                                <RadioButton Content="مالیات"
                                              Visibility="Collapsed"
                                              Style="{StaticResource ModernTabButton}"
                                              x:Name="TabTax"
                                            
                                              Margin="10,0,6,0"
                                              Checked="TabTax_Checked" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border  Style="{StaticResource CardPanel}"
                             Grid.Row="1">
                        <StackPanel>




                            <StackPanel  Grid.Column="1">

                                <StackPanel x:Name="PricingContent"
                                            Width="650"
                                            Visibility="Visible">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            
                                            <ColumnDefinition Width="16" />
                                            
                                            <ColumnDefinition Width="Auto" />
                                            
                                        </Grid.ColumnDefinitions>

                                        
                                        <StackPanel Grid.Column="0">
                                            
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="شماره تلفن"
                                                               Style="{StaticResource FormLabel}" />
                                                    <controls:ModernPersianTextBox Width="200"
                                                                                   FlowDirection="LeftToRight"
                                                                                   Text="{Binding TelePhone, UpdateSourceTrigger=PropertyChanged}"
                                                                                   Placeholder="071" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="موبایل"
                                                               Style="{StaticResource FormLabel}" />
                                                    <controls:ModernPersianTextBox Width="200"
                                                                                   FlowDirection="LeftToRight"
                                                                                   Text="{Binding MobilePhone, UpdateSourceTrigger=PropertyChanged}"
                                                                                   Placeholder="091" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="ایمیل "
                                                               Style="{StaticResource FormLabel}" />
                                                    <controls:ModernPersianTextBox Width="200"
                                                                                   Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                                                   Placeholder="example@mail.com" />
                                                </StackPanel>
                                            </Grid>

                                            
                                       
                                        </StackPanel>

                                     
                                    </Grid>

                                </StackPanel>


                                <StackPanel x:Name="InventoryContent"
                                            Width="650"
                                            Visibility="Collapsed">


                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                     
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="استان"
                                                       Style="{StaticResource FormLabel}" />
                                            <ComboBox x:Name="ProvinceComboBox"
                                                      Width="170"
                                                      ItemsSource="{Binding Provinces}"
                                                      DisplayMemberPath="Title"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedProvinceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectionChanged="ProvinceComboBox_SelectionChanged"
                                                      Style="{StaticResource SearchableComboBox}"
                                                      ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                        </StackPanel>



                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="کد پستی"
                                                       Width="170"
                                                       HorizontalAlignment="Left"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding PostCode, UpdateSourceTrigger=PropertyChanged}"
                                                                           FlowDirection="LeftToRight"
                                                                           Placeholder="74100" />

                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="آدرس"
                                                       Width="300"
                                                       HorizontalAlignment="Left"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           
                                                                           Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="آدرس کامل شعبه" />

                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="CityLoadingOverlay"
                                                Background="#99FAFCFF"
                                                Visibility="Collapsed"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="در حال بارگذاری شهرستان‌ها..."
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="شهرستان"
                                                       Style="{StaticResource FormLabel}" />
                                            <ComboBox x:Name="CityComboBox"
                                                      Width="170"
                                                      ItemsSource="{Binding Cities}"
                                                      DisplayMemberPath="Title"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedCityId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource SearchableComboBox}"
                                                      ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="مختصات مکان X"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox x:Name="LatitudeField"
                                                                           Text="{Binding LatitudeText, UpdateSourceTrigger=PropertyChanged}"
                                                                           FlowDirection="LeftToRight"
                                                                           InputType="Text"
                                                                           Width="170"
                                                                           Placeholder="35.6892" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="مختصات مکان Y"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox x:Name="LongitudeField"
                                                                           Text="{Binding LongitudeText, UpdateSourceTrigger=PropertyChanged}"
                                                                           FlowDirection="LeftToRight"
                                                                           InputType="Text"
                                                                           Width="170"
                                                                           Placeholder="51.3890" />
                                        </StackPanel>

                                    </Grid>


                                </StackPanel>


                                <StackPanel x:Name="TaxContent"
                                            Visibility="Collapsed">



                                    <Grid Margin="0,0,0,10"
                                          HorizontalAlignment="Left"
                                          MaxWidth="700">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>


                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="اعتبار مالی"
                                                       Width="200"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="شناسه/کدملی"
                                                       Width="200"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="1234" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="کد اقتصادی"
                                                       Width="200"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="1234" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>


                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="شماره ثبت شرکت"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Width="230"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="1234" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="تاریخ تولد"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:PersianDatePickerControl x:Name="MyDatePicker2"
                                                                               Width="235"
                                                                               SelectedDate="{Binding BirthDate}"
                                                                               DateChanged="MyDatePicker_DateChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="تاریخ عضویت"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:PersianDatePickerControl x:Name="MyDatePicker"
                                                                               Width="280"
                                                                               SelectedDate="{Binding BirthDate}"
                                                                               DateChanged="MyDatePicker_DateChanged" />


                                        </StackPanel>

                                    </Grid>
                                    <TextBlock Text="توضیحات"
                                               Style="{StaticResource FormLabel}" />
                                    <TextBox Text="{Binding CurrentProduct.ProductName, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="نام کالا را وارد کنید"
                                             Style="{StaticResource ModernPersianTextBox}"
                                             Width="720"
                                             HorizontalAlignment="Left"
                                             FontFamily="{StaticResource IRANSans}"
                                             Margin="0,0,0,8" />

                                </StackPanel>

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>


            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>