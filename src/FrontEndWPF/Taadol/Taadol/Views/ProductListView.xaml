<UserControl x:Class="Taadol.Views.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             d:DesignHeight="650"
             d:DesignWidth="1440"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Margin="24"
             FlowDirection="RightToLeft"
             FontFamily="{StaticResource IRANSans}"
             Background="#FFFFFF">

    <UserControl.Resources>
        
        <Style x:Key="FilterTabStyle2"
               TargetType="RadioButton">
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Width"
                    Value="215" />
            <Setter Property="Foreground"
                    Value="#2563EB" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="16,10" />
            <Setter Property="Margin"
                    Value="0,0,4,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Border x:Name="CheckBoxBorder"
                                            Width="20"
                                            Height="20"
                                            BorderThickness="2"
                                            BorderBrush="#2ECC71"
                                            CornerRadius="4"
                                            Background="White"
                                            Padding="2"
                                            Margin="0,0,6,0"
                                            Visibility="Collapsed">
                                        <svg:SvgViewbox x:Name="CheckMark"
                                                        Width="8"
                                                        Height="8"
                                                        Source="/Assets/Icons/Line.svg"
                                                        FlowDirection="LeftToRight"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                    </Border>

                                    <TextBlock x:Name="TitleText"
                                               Text="{TemplateBinding Content}"
                                               Foreground="#2563EB"
                                               FontWeight="Medium" />
                                </StackPanel>

                                
                                <TextBlock Grid.Column="2"
                                           x:Name="CountText"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#94A3B8"
                                           FontWeight="Normal"
                                           HorizontalAlignment="Left" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="#2563EB" />
                                <Setter TargetName="Root"
                                        Property="BorderThickness"
                                        Value="1" />

                                <Setter TargetName="TitleText"
                                        Property="Foreground"
                                        Value="#2563EB" />
                                <Setter TargetName="TitleText"
                                        Property="FontWeight"
                                        Value="Bold" />
                                <Setter TargetName="CountText"
                                        Property="Foreground"
                                        Value="#64748B" />

                                
                                <Setter TargetName="CheckBoxBorder"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="False">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter TargetName="Root"
                                        Property="BorderBrush"
                                        Value="#E9F0FF" />
                                <Setter TargetName="Root"
                                        Property="BorderThickness"
                                        Value="1" />

                                <Setter TargetName="TitleText"
                                        Property="Foreground"
                                        Value="#2563EB" />
                                <Setter TargetName="TitleText"
                                        Property="FontWeight"
                                        Value="Bold" />
                                <Setter TargetName="CountText"
                                        Property="Foreground"
                                        Value="#64748B" />
                            </Trigger>
                            
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="#F4F7FF" />
                            </Trigger>

                            
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="TitleText"
                                        Property="Foreground"
                                        Value="#CBD5E1" />
                                <Setter TargetName="CountText"
                                        Property="Foreground"
                                        Value="#E2E8F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="FilterTabStyle"
               TargetType="RadioButton">
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Foreground"
                    Value="#64748B" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="Transparent"
                                BorderThickness="0,0,0,2.5"
                                BorderBrush="Transparent"
                                Padding="22,11"
                                SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Border x:Name="checkIcon"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="4"
                                        Background="#22C55E"
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <TextBlock Text="✓"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               FontFamily="{StaticResource IRANSans}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,-1,0,0" />
                                </Border>

                                <TextBlock x:Name="txt"
                                           Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center"
                                           FontWeight="Medium"
                                           FontFamily="{StaticResource IRANSans}" />

                                <Border x:Name="countBorder"
                                        Background="#F1F5F9"
                                        CornerRadius="8"
                                        Padding="8,3"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="countText"
                                               Text="{TemplateBinding Tag}"
                                               FontSize="11"
                                               Foreground="#94A3B8"
                                               FontFamily="{StaticResource IRANSans}" />
                                </Border>

                                <Border x:Name="separator"
                                        Width="1"
                                        Height="20"
                                        Background="#E2E8F0"
                                        Margin="22,0,0,0"
                                        VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="txt"
                                        Property="Foreground"
                                        Value="#1E40AF" />
                                <Setter TargetName="txt"
                                        Property="FontWeight"
                                        Value="Bold" />
                                <Setter TargetName="bd"
                                        Property="BorderBrush"
                                        Value="#3B82F6" />
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#F0F7FF" />
                                <Setter TargetName="countBorder"
                                        Property="Background"
                                        Value="#DBEAFE" />
                                <Setter TargetName="countText"
                                        Property="Foreground"
                                        Value="#2563EB" />
                                <Setter TargetName="checkIcon"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#F8FAFC" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked"
                                               Value="True" />
                                    <Condition Property="IsMouseOver"
                                               Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#E8F1FF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Margin="0,16"
            Background="White"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0"
                    Padding="24,18"
                    Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="16"
                                        Height="16"
                                        Source="/Assets/Icons/arrow-right_BLUE.svg"
                                        Margin="5,0,10,0" />
                        <TextBlock x:Name="HeaderTitle"
                                   Text="کالاها و خدمات"
                                   FontSize="19"
                                   FontFamily="{StaticResource IRANSans}"
                                   FontWeight="Bold"
                                   Foreground="#001242"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="RightToLeft">

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnMore_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/MORE.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnDelete_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/trash.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#FEF2F2" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnEdit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/EDIT.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnNew_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/newdoc21.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0FFF4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            
            <Border Grid.Row="1"
                    BorderBrush="#E9E5FF"
                    BorderThickness="0,1,0,0"
                    Background="#FAFBFF"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal"
                            FlowDirection="RightToLeft"
                            VerticalAlignment="Center">
                

                    <RadioButton x:Name="tabAllTypes"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="ItemType"
                                 Content="همه"
                                 Tag="۹۰"
                                 IsChecked="True"
                                 Checked="TypeTab_Checked" />

                    <RadioButton x:Name="tabProducts"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="ItemType"
                                 Content="کالاها"
                                 Tag="۶۸"
                                 Checked="TypeTab_Checked" />

                    <RadioButton x:Name="tabServices"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="ItemType"
                                 Content="خدمات"
                                 Tag="۲۲"
                                 Checked="TypeTab_Checked" />
                </StackPanel>
            </Border>

            
            <Border Grid.Row="2"
                    BorderBrush="#D4E0FF"
                    BorderThickness="0,2,0,0"
                    Background="#FAFCFF"
                    Padding="24,12">
             
            </Border>

            
            <Border Grid.Row="3"
                    Background="Transparent"
                    ClipToBounds="False"
                    Padding="15,0">

                <Grid x:Name="DataGridContainer">
                    <Grid.Resources>
                        <Style x:Key="BaseTextColumnStyle"
                               TargetType="TextBlock">
                            <Setter Property="FontFamily"
                                    Value="{StaticResource IRANSans}" />
                            <Setter Property="HorizontalAlignment"
                                    Value="Center" />
                            <Setter Property="VerticalAlignment"
                                    Value="Center" />
                            <Setter Property="Foreground"
                                    Value="#5C5C5C" />
                        </Style>

                        <Style x:Key="LtrTextColumnStyle"
                               TargetType="TextBlock"
                               BasedOn="{StaticResource BaseTextColumnStyle}">
                            <Setter Property="FlowDirection"
                                    Value="LeftToRight" />
                        </Style>

                        <Style x:Key="RowNumberColumnStyle"
                               TargetType="TextBlock"
                               BasedOn="{StaticResource BaseTextColumnStyle}">
                            <Setter Property="Foreground"
                                    Value="#94A3B8" />
                            <Setter Property="FontWeight"
                                    Value="SemiBold" />
                        </Style>

                        <Style x:Key="ProductNameColumnStyle"
                               TargetType="TextBlock"
                               BasedOn="{StaticResource BaseTextColumnStyle}">
                            <Setter Property="Foreground"
                                    Value="#5C5C5C" />
                            <Setter Property="FontWeight"
                                    Value="SemiBold" />
                        </Style>
                    </Grid.Resources>

                    <DataGrid x:Name="ProductsDataGrid"
                              CanUserSortColumns="False"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              VerticalGridLinesBrush="#CCD0D9"
                              HorizontalGridLinesBrush="#CCD0D9"
                              RowHeight="30"
                              Background="White"
                              BorderBrush="#CCD0D9"
                              BorderThickness="1"
                              SnapsToDevicePixels="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              AlternationCount="2"
                              IsReadOnly="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              FontFamily="{StaticResource IRANSans}"
                              SelectionChanged="ProductsDataGrid_SelectionChanged">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Tag"
                                        Value="True" />
                                <Setter Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#0D2159" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                                <Setter Property="Padding"
                                        Value="10,0" />
                                <Setter Property="BorderBrush"
                                        Value="#BED1FF" />
                                <Setter Property="BorderThickness"
                                        Value="1,2,1,2" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                                <Setter Property="Height"
                                        Value="46" />

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <ContentPresenter Grid.Column="0"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center" />

                                                    <svg:SvgViewbox x:Name="FilterIcon"
                                                                    Width="13"
                                                                    Height="13"
                                                                    Grid.Column="1"
                                                                    Source="/Assets/Icons/filter-search.svg"
                                                                    VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Tag"
                                                         Value="False">
                                                    <Setter TargetName="FilterIcon"
                                                            Property="Visibility"
                                                            Value="Collapsed" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#5C5C5C" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                                <Setter Property="Padding"
                                        Value="8,0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E8F2FF" />
                                        <Setter Property="Foreground"
                                                Value="#2667FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="Background"
                                        Value="#FFFFFF" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex"
                                             Value="1">
                                        <Setter Property="Background"
                                                Value="#E5E7EC" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#F0F5FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E8F2FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Width="50"
                                                Binding="{Binding RowNumberDisplay}"
                                                ElementStyle="{StaticResource RowNumberColumnStyle}">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="کد"
                                                Width="85"
                                                Binding="{Binding Code}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTextColumn Header="دسته بندی"
                                                Width="110"
                                                Binding="{Binding Category}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTextColumn Header="نام"
                                                Width="140"
                                                Binding="{Binding Name}"
                                                ElementStyle="{StaticResource ProductNameColumnStyle}" />

                            <DataGridTextColumn Header="بارکد"
                                                Width="100"
                                                Binding="{Binding Barcode}"
                                                ElementStyle="{StaticResource LtrTextColumnStyle}" />

                            <DataGridTextColumn Header="کد محصول"
                                                Width="120"
                                                Binding="{Binding Code}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTextColumn Header="واحد"
                                                Width="80"
                                                Binding="{Binding Unit}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTextColumn Header="تعداد"
                                                Width="80"
                                                Binding="{Binding Quantity}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTemplateColumn Header="وضعیت"
                                                    Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,3"
                                                CornerRadius="5"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding StatusVisibility}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="غیرفعال">
                                                            <Setter Property="Background"
                                                                    Value="#FEE2E2" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="فعال">
                                                            <Setter Property="Background"
                                                                    Value="#DCFCE7" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       FontFamily="{StaticResource IRANSans}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="غیرفعال">
                                                                <Setter Property="Foreground"
                                                                        Value="#991B1B" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="فعال">
                                                                <Setter Property="Foreground"
                                                                        Value="#166534" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="توضیحات"
                                                Width="250"
                                                Binding="{Binding Description}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTextColumn Header="قیمت خرید"
                                                Width="140"
                                                Binding="{Binding PurchasePriceFormatted}"
                                                ElementStyle="{StaticResource LtrTextColumnStyle}" />

                            <DataGridTextColumn Header="قیمت فروش"
                                                Width="140"
                                                Binding="{Binding SalePriceFormatted}"
                                                ElementStyle="{StaticResource LtrTextColumnStyle}" />

                            <DataGridTextColumn Header="مالیات"
                                                Width="120"
                                                Binding="{Binding TaxFormatted}"
                                                ElementStyle="{StaticResource LtrTextColumnStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            
            <Border Grid.Row="4"
                    Padding="5,14"
                    Background="White"
                    BorderBrush="#E9F0FF"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="LeftToRight">

                        <Button Width="34"
                                Height="34"
                                Margin="0,0,2,0"
                                Cursor="Hand"
                                Click="BtnPrevPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30"
                                            Background="Transparent">
