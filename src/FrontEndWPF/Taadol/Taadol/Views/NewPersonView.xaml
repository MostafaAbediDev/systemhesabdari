                                                VerticalAlignment="Stretch">
                                            <StackPanel>
                                                <TextBlock Text="آدرس"
                                                           Style="{StaticResource FormLabel}"
                                                           Margin="0,0,0,8" />
                                                <TextBox Text="{Binding Address}"
                                                         Style="{StaticResource ModernPersianTextBox}"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         Height="120"
                                                         VerticalAlignment="Top"
                                                         materialDesign:HintAssist.Hint="آدرس را وارد کنید..." />
                                            </StackPanel>
                                        </Border>

                                    </Grid>

                                </StackPanel>

                                <StackPanel x:Name="InventoryContent"
                                            Visibility="Visible">

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="نام بانک"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Width="230"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="ملت" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="نام شعبه"
                                                       Width="230"
                                                       HorizontalAlignment="Left"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="مرکزی" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,30,0,0">
                                            <ToggleButton Content="حساب پیش فرض"
                                                          FlowDirection="LeftToRight"
                                                          Style="{StaticResource StatusToggleButton}"
                                                          IsChecked="True"
                                                          Margin="10,0,60,0" />

                                            
                                            <Button x:Name="AddBankAccountButton"
                                                    Click="AddBankAccountButton_Click"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand">
                                                <svg:SvgViewbox Width="18"
                                                                Height="18"
                                                                Source="/Assets/Icons/addAc.svg" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="شماره کارت"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Width="230"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="**** **** **** ****" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="شماره شبا"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Width="230"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="IR" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="شماره حساب"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Width="230"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="456" />
                                        </StackPanel>
                                    </Grid>

                                    
                                    <ItemsControl x:Name="AdditionalBankAccountsPanel"
                                                  Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <StaticResource ResourceKey="BankAccountTemplate" />
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel x:Name="TaxContent"
                                            Visibility="Collapsed">



                                    <Grid Margin="0,0,0,10"
                                          HorizontalAlignment="Left"
                                          MaxWidth="700">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>


                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="اعتبار مالی"
                                                       Width="200"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="شناسه/کدملی"
                                                       Width="200"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="1234" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="کد اقتصادی"
                                                       Width="200"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="1234" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>


                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="شماره ثبت شرکت"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Grid.Column="0"
                                                                           Width="230"
                                                                           Text="{Binding Username}"
                                                                           Placeholder="1234" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="تاریخ تولد"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:PersianDatePickerControl x:Name="MyDatePicker2"
                                                                               Width="235"
                                                                               SelectedDate="{Binding BirthDate}"
                                                                               DateChanged="MyDatePicker_DateChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="تاریخ عضویت"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:PersianDatePickerControl x:Name="MyDatePicker"
                                                                               Width="280"
                                                                               SelectedDate="{Binding BirthDate}"
                                                                               DateChanged="MyDatePicker_DateChanged" />


                                        </StackPanel>

                                    </Grid>
                                    <TextBlock Text="توضیحات"
                                               Style="{StaticResource FormLabel}" />
                                    <TextBox Text="{Binding CurrentProduct.ProductName, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="نام کالا را وارد کنید"
                                             Style="{StaticResource ModernPersianTextBox}"
                                             Width="720"
                                             HorizontalAlignment="Left"
                                             FontFamily="{StaticResource IRANSans}"
                                             Margin="0,0,0,8" />

                                </StackPanel>

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>


            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>