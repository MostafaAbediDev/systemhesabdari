<UserControl x:Class="Taadol.Views.NewPersonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Taadol.ViewModels"
             xmlns:controls="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             VerticalAlignment="Stretch"
             Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="BankAccountTemplate">
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    Padding="0,15,0,15"
                    Margin="0,5,0,5">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="نام بانک"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           Text="{Binding BankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Placeholder="ملت" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="نام شعبه"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           Text="{Binding BranchName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Placeholder="مرکزی" />
                        </StackPanel>

                        <StackPanel Grid.Column="5"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="15,0,0,0">
                            <ToggleButton Content="حساب پیش فرض"
                                          FlowDirection="LeftToRight"
                                          Style="{StaticResource StatusToggleButton}"
                                          IsChecked="{Binding IsDefault, Mode=TwoWay}"
                                          Margin="0,0,10,0" />
                            <Button x:Name="RemoveButton"
                                    Click="RemoveBankAccount_Click"
                                    Tag="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="5,0,0,0">
                                <svg:SvgViewbox Width="16"
                                                Height="16"
                                                Source="/Assets/Icons/delete.svg" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="شماره کارت"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           FlowDirection="LeftToRight"
                                                           Text="{Binding CardNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Placeholder="**** **** **** ****" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="شماره شبا"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           FlowDirection="LeftToRight"
                                                           Text="{Binding Shaba, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Placeholder="IR" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="شماره حساب"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           FlowDirection="LeftToRight"
                                                           Text="{Binding AccountNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Placeholder="456" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════
         ساختار اصلی: Grid با 4 ردیف
         ردیف 0: هدر (ثابت)
         ردیف 1: CardPanel اصلی (ثابت)
         ردیف 2: تب بار (ثابت)
         ردیف 3: محتوای تب‌ها (اسکرول‌پذیر)
    ════════════════════════════════════════════════════ -->
    <Border CornerRadius="12"
            ClipToBounds="False"
            Background="#ffffff"
            VerticalAlignment="Stretch"
            Margin="24,12">
        <Border.Effect>
            <DropShadowEffect Color="#C8A882"
                              Opacity="0.4"
                              BlurRadius="20"
                              ShadowDepth="0"
                              Direction="270" />
        </Border.Effect>
        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══ ردیف 0: هدر ═══ -->
            <Grid Grid.Row="0"
                  Margin="10,15,10,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <svg:SvgViewbox FlowDirection="LeftToRight"
                                    Width="14"
                                    Height="14"
                                    Source="/Assets/Icons/arrow-right.svg"
                                    Margin="10,0,10,0" />
                    <TextBlock Text="مشخصات شخص جدید"
                               FontSize="18"
                               FontWeight="Bold"
                               FontFamily="{StaticResource IRANSans}"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <controls:CustomOutlinedButton Margin="0,0,12,0"
                                                   Text="ثبت موقت">
                        <controls:CustomOutlinedButton.Icon>
                            <svg:SvgViewbox Source="/Assets/Icons/tempsave.svg"
                                            Width="16"
                                            Height="16" />
                        </controls:CustomOutlinedButton.Icon>
                    </controls:CustomOutlinedButton>
                    <controls:IconButton ButtonText="ثبت"
                                         IconSource="/Assets/Icons/save.svg"
                                         ButtonCommand="{Binding SavePersonCommand}"
                                         ButtonBackground="#2667FF" />
                </StackPanel>
            </Grid>

            <!-- خط جداکننده دش‌دار -->
            <Border Grid.Row="0"
                    Height="1"
                    Margin="7,0,7,2"
                    VerticalAlignment="Bottom">
                <Border.Background>
                    <VisualBrush TileMode="Tile"
                                 Viewport="0,0,10,1"
                                 ViewportUnits="Absolute"
                                 Viewbox="0,0,10,1"
                                 ViewboxUnits="Absolute">
                        <VisualBrush.Visual>
                            <Grid Width="10"
                                  Height="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="5" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0"
                                           Fill="#D4E0FF" />
                                <Rectangle Grid.Column="1"
                                           Fill="#D4E0FF" />
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.Background>
            </Border>

            <!-- ═══ ردیف 1: CardPanel اصلی (اطلاعات شخص) ═══ -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="شناسه یکتا"
                                       Style="{StaticResource FormLabel}" />
                        </StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <controls:ModernPersianTextBox Grid.Column="0"
                                                           x:Name="ManualCodeTextBox"
                                                           Text="{Binding ManualCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsEnabled="False"
                                                           Placeholder="1234" />
                            <controls:ToggleSwitchControl x:Name="CodeModeToggle"
                                                          Margin="12,0,0,0"
                                                          FirstLabel="اتوماتیک"
                                                          SecondLabel="دستی"
                                                          IsFirstSelected="True"
                                                          Grid.Column="1"
                                                          SelectionChanged="CodeModeToggle_SelectionChanged" />
                        </Grid>

                        <TextBlock Text="انتخاب شعبه"
                                   Style="{StaticResource FormLabel}" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Grid Width="315">
                                <ComboBox x:Name="BranchCombo"
                                          Style="{StaticResource SearchableComboBox}"
                                          Tag="جستجو..."
                                          Width="315"
                                          ItemsSource="{Binding Branches}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedBranchId, Mode=TwoWay}"
                                          ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />

                                <!-- اسپینر لود روی فلش ComboBox شعبه
                                     (الگو از NewBranchView.xaml: CompanyComboLoading) -->
                                <Border x:Name="BranchComboLoading"
                                        Width="42"
                                        Height="42"
                                        Background="White"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        IsHitTestVisible="False"
                                        CornerRadius="8">

                                    <Grid Width="22"
                                          Height="22"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">

                                        <Grid.RenderTransform>
                                            <RotateTransform x:Name="BranchComboSpinnerRotate"
                                                             Angle="0" />
                                        </Grid.RenderTransform>

                                        <Ellipse Width="20"
                                                 Height="20"
                                                 Stroke="#D4E0FF"
                                                 StrokeThickness="3" />

                                        <Path Stroke="#2667FF"
                                              StrokeThickness="3"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M 11,1 A 10,10 0 0 1 21,11" />

                                        <Grid.Triggers>
                                            <EventTrigger RoutedEvent="Grid.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetName="BranchComboSpinnerRotate"
                                                                         Storyboard.TargetProperty="Angle"
                                                                         From="0"
                                                                         To="360"
                                                                         Duration="0:0:0.8" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Grid.Triggers>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition MaxHeight="625" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="نوع شخص"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ToggleSwitchControl x:Name="LegalTypeToggle"
                                                              FirstLabel="حقیقی"
                                                              SecondLabel="حقوقی"
                                                              IsFirstSelected="True"
                                                              Grid.Column="1"
                                                              Margin="9,0,0,0"
                                                              SelectionChanged="LegalTypeToggle_SelectionChanged" />
                                <ToggleButton x:Name="PersonActiveToggle"
                                              Content=".شخص فعال است"
                                              FlowDirection="LeftToRight"
                                              Style="{StaticResource StatusToggleButton}"
                                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                                              Margin="10,0,18,0" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,5,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        x:Name="FirstNamePanel">
                                <TextBlock Text="نام"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="علی" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        x:Name="LastNamePanel">
                                <TextBlock Text="نام خانوادگی"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="علوی" />
                            </StackPanel>
                            <StackPanel Grid.Column="4"
                                        x:Name="NationalCodePanel">
                                <TextBlock Text="کد ملی"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                               Text="{Binding NationalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="2470545256" />
                            </StackPanel>

                            <StackPanel Grid.Column="0"
                                        x:Name="CompanyNamePanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="نام شرکت"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="شرکت نمونه" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        x:Name="EconomicCodePanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="کد اقتصادی"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                               Text="{Binding EconomicCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="123456789" />
                            </StackPanel>
                            <StackPanel Grid.Column="4"
                                        x:Name="RegistrationNumberPanel"
                                        Visibility="Collapsed">
                                <TextBlock Text="شماره ثبت"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox FlowDirection="LeftToRight"
                                                               Text="{Binding RegistrationNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Placeholder="12345" />
                            </StackPanel>
                        </Grid>

                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="55" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Margin="0,0,0,5"
                                               Text="دسته کلی"
                                               Style="{StaticResource FormLabel}"
                                               VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal"
                                                Grid.Row="1">
                                        <ToggleButton x:Name="PersonTypeCustomer"
                                                      Content="مشتری"
                                                      Tag="1"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton x:Name="PersonTypeSupplier"
                                                      Content="تامین کننده"
                                                      Tag="3"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton x:Name="PersonTypeBoth"
                                                      Content="هردو"
                                                      Tag="1"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton x:Name="PersonTypePersonnel"
                                                      Content="پرسنل"
                                                      Tag="2"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="PersonTypeToggle_Checked"
                                                      Margin="0,0,8,0" />
                                        <ToggleButton Content="مشخصات پرسنل"
                                                      x:Name="PersonnelToggle"
                                                      FlowDirection="LeftToRight"
                                                      Style="{StaticResource StatusToggleButton}"
                                                      IsChecked="False"
                                                      Checked="CategoryToggle_Checked"
                                                      Unchecked="CategoryToggle_Checked"
                                                      Margin="0,0,8,0" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <controls:CategorySearchControl x:Name="CategorySearch"
                                                                Width="350"
                                                                MainIconSource="/Assets/Icons/custom_icon.svg" />
                            </StackPanel>
                        </Grid>

                    </StackPanel>

                    <!-- تصویر -->
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                        <controls:ImagePickerControl ImageSelected="OnImageSelected"
                                                     ImageRemoved="OnImageRemoved"
                                                     Loaded="ImagePickerControl_Loaded" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ ردیف 2: جداکننده دکمه‌ای ═══ -->
            <Grid Grid.Row="2"
                  Margin="0,0,0,2">
                <Border Height="3">
                    <Border.Background>
                        <VisualBrush TileMode="Tile"
                                     Viewport="0,0,10,1"
                                     ViewportUnits="Absolute"
                                     Viewbox="0,0,10,1"
                                     ViewboxUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="10"
                                      Height="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="5" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Fill="#BED1FF" />
                                    <Rectangle Grid.Column="1"
                                               Fill="Transparent" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>
                <Ellipse Width="17"
                         Margin="-9,0,0,0"
                         Height="25"
                         Fill="#FFF8ED"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Panel.ZIndex="2" />
                <Ellipse Width="17"
                         Height="25"
                         Margin="0,0,-9,0"
                         Fill="#FFF8ED"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Panel.ZIndex="2" />
            </Grid>

            <!-- ═══ ردیف 3: تب بار (ثابت، اسکرول نمی‌شه) ═══ -->
            <StackPanel Grid.Row="3"
                        Margin="20,0,0,0"
                        HorizontalAlignment="Left">
                <Border CornerRadius="12"
                        BorderThickness="1.5"
                        BorderBrush="#BED1FF"
                        Background="#F8FAFF"
                        Padding="4"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="تماس و آدرس"
                                     Style="{StaticResource ModernTabButton}"
                                     Margin="10,0,6,0"
                                     IsChecked="True"
                                     GroupName="PersonTabs"
                                     x:Name="TabPricing"
                                     Checked="TabPricing_Checked" />

                        <RadioButton Content="حساب های بانکی"
                                     Style="{StaticResource ModernTabButton}"
                                     Margin="10,0,6,0"
                                     GroupName="PersonTabs"
                                     x:Name="TabInventory"
                                     Checked="TabInventory_Checked" />

                        <RadioButton Content="مشخصات پرسونل"
                                     Visibility="Collapsed"
                                     Style="{StaticResource ModernTabButton}"
                                     Margin="10,0,6,0"
                                     GroupName="PersonTabs"
                                     x:Name="TabTax"
                                     Checked="TabTax_Checked" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══ ردیف 4: محتوای تب‌ها — فقط اینجا اسکرول می‌شه ═══ -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Border Style="{StaticResource CardPanel}">
                    <Grid>

                        <!-- تب: تماس و آدرس -->
                        <StackPanel x:Name="PricingContent"
                                    Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="شماره تلفن"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="071" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="استان"
                                                       Style="{StaticResource FormLabel}" />
                                            <ComboBox x:Name="ProvinceCombo"
                                                      Style="{StaticResource SearchableComboBox}"
                                                      Tag="جستجو"
                                                      Width="200"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding Provinces}"
                                                      DisplayMemberPath="Title"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedProvinceId, Mode=TwoWay}"
                                                      ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="کد پستی"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           Text="{Binding PostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="موبایل"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Mobile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="091" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="شهرستان"
                                                       Style="{StaticResource FormLabel}" />
                                            <ComboBox x:Name="CityCombo"
                                                      Style="{StaticResource SearchableComboBox}"
                                                      Tag="جستجو..."
                                                      Width="200"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding Cities}"
                                                      DisplayMemberPath="Title"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding SelectedCityId, Mode=TwoWay}"
                                                      ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="ایمیل"
                                                       Style="{StaticResource FormLabel}" />
                                            <controls:ModernPersianTextBox Width="200"
                                                                           FlowDirection="LeftToRight"
                                                                           Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           Placeholder="example@mail.com" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Width="208"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Padding="0"
                                        VerticalAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Text="آدرس"
                                                   Style="{StaticResource FormLabel}"
                                                   Margin="0,0,0,8" />
                                        <TextBox Text="{Binding Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernPersianTextBox}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Height="120"
                                                 VerticalAlignment="Top"
                                                 materialDesign:HintAssist.Hint="آدرس را وارد کنید..." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- تب: حساب های بانکی -->
                        <StackPanel x:Name="InventoryContent"
                                    Visibility="Collapsed">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="نام بانک"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="230"
                                                                   Text="{Binding MainBankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="ملت" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="نام شعبه"
                                               Width="230"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource FormLabel}" />
                                    <ComboBox x:Name="BankBranchCombo"
                                              Style="{StaticResource SearchableComboBox}"
                                              Tag="جستجو..."
                                              Width="230"
                                              HorizontalAlignment="Left"
                                              ItemsSource="{Binding BankBranches}"
                                              DisplayMemberPath="BranchName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedBankBranchId, Mode=TwoWay}"
                                              ItemContainerStyle="{StaticResource SearchableComboBoxItem}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            Margin="0,30,0,0">
                                    <ToggleButton x:Name="MainBankDefaultToggle"
                                                  Content="حساب پیش فرض"
                                                  FlowDirection="LeftToRight"
                                                  Style="{StaticResource StatusToggleButton}"
                                                  IsChecked="{Binding MainBankIsDefault, Mode=TwoWay}"
                                                  Margin="10,0,60,0" />
                                    <Button x:Name="AddBankAccountButton"
                                            Click="AddBankAccountButton_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/addAc.svg" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="شماره کارت"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="230"
                                                                   FlowDirection="LeftToRight"
                                                                   Text="{Binding MainCardNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="**** **** **** ****" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="شماره شبا"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="230"
                                                                   FlowDirection="LeftToRight"
                                                                   Text="{Binding MainShaba, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="IR" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="شماره حساب"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="230"
                                                                   FlowDirection="LeftToRight"
                                                                   Text="{Binding MainAccountNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="456" />
                                </StackPanel>
                            </Grid>

                            <!-- حساب‌های بانکی اضافه‌شده -->
                            <ItemsControl x:Name="AdditionalBankAccountsPanel"
                                          Margin="0,10,0,0"
                                          ItemsSource="{Binding BankAccounts}">
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="BankAccountTemplate" />
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- تب: مالیات -->
                        <StackPanel x:Name="TaxContent"
                                    Visibility="Visible">
                            <Grid Margin="0,0,0,10"
                                  HorizontalAlignment="Left"
                                  MaxWidth="700">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <controls:CategorySearchControl x:Name="CategorySearch2"
                                                                    Width="300"
                                                                    HeaderText="دپارتمان"
                                                                    MainIconSource="/Assets/Icons/custom_icon.svg" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <controls:CategorySearchControl x:Name="CategorySearc3"
                                                                    Width="300"
                                                                    HeaderText="عنوان شغل"
                                                                    MainIconSource="/Assets/Icons/custom_icon.svg" />
                                </StackPanel>

                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Margin="0,0,0,5"
                                                       Text="دسته کلی"
                                                       Style="{StaticResource FormLabel}"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal"
                                                        Grid.Row="2">
                                                <ToggleButton Content="رسمی"
                                                              FlowDirection="LeftToRight"
                                                              Style="{StaticResource StatusToggleButton}"
                                                              IsChecked="False"
                                                              Margin="0,0,8,0" />
                                                <ToggleButton Content="قراردادی"
                                                              FlowDirection="LeftToRight"
                                                              Style="{StaticResource StatusToggleButton}"
                                                              IsChecked="False"
                                                              Margin="0,0,8,0" />
                                                <ToggleButton Content="پروژه ای"
                                                              FlowDirection="LeftToRight"
                                                              Style="{StaticResource StatusToggleButton}"
                                                              IsChecked="False"
                                                              Margin="0,0,8,0" />

                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="کد پرسنلی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="230"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="**** **** **** ****" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="شماره بیمه"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="230"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="12345" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="حقوق پایه"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Width="300"
                                                                   FlowDirection="LeftToRight"
                                                                   Placeholder="071" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="تاریخ استخدام"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:PersianDatePickerControl x:Name="MyDatePicker3"
                                                                       DateChanged="MyDatePicker_DateChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="تاریخ قطع همکاری"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:PersianDatePickerControl x:Name="MyDatePicker2"
                                                                       DateChanged="MyDatePicker_DateChanged" />
                                </StackPanel>
                            </Grid>
                            <StackPanel>
                                <TextBlock Text="توضیحات"
                                           Style="{StaticResource FormLabel}" />
                                <controls:ModernPersianTextBox Width="730"
                                                               Placeholder=""
                                                               HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </Border>
            </ScrollViewer>

        </Grid>
    </Border>

</UserControl>