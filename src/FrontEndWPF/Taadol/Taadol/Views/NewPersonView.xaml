             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Taadol.ViewModels"
             xmlns:controls="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             Background="Transparent">

    <UserControl.Resources>
        <DataTemplate x:Key="BankAccountTemplate">
            <Border BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    Padding="0,15,0,15"
                    Margin="0,5,0,5">

                
                <StackPanel>

                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="نام بانک"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           Placeholder="ملت" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="نام شعبه"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           Placeholder="مرکزی" />
                        </StackPanel>


                        <StackPanel Grid.Column="6"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="15,0,0,0">
                            <ToggleButton Content="حساب پیش فرض"
                                          FlowDirection="LeftToRight"
                                          Style="{StaticResource StatusToggleButton}"
                                          Margin="0,0,10,0" />

                            <Button x:Name="RemoveButton"
                                    Click="RemoveBankAccount_Click"
                                    Tag="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Margin="5,0,0,0">
                                <svg:SvgViewbox Width="16"
                                                Height="16"
                                                Source="/Assets/Icons/delete.svg" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="شماره کارت"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           FlowDirection="LeftToRight"
                                                           Placeholder="**** **** **** ****" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="شماره شبا"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           FlowDirection="LeftToRight"
                                                           Placeholder="IR" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="شماره حساب"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Width="230"
                                                           FlowDirection="LeftToRight"
                                                           Placeholder="456" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>
        </DataTemplate>
