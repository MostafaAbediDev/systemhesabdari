<UserControl x:Class="Taadol.Views.PersonListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             d:DesignHeight="700"
             d:DesignWidth="1500"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:System="http://schemas.microsoft.com/winfx/2009/xaml"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             Margin="24"
             Padding="0"
             FontFamily="{StaticResource IRANSans}"
             Background="#FFFFFF">

    <UserControl.Resources>

        <Style x:Key="FilterTabStyle"
               TargetType="RadioButton">
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Foreground"
                    Value="#64748B" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="Transparent"
                                BorderThickness="0,0,0,2.5"
                                BorderBrush="Transparent"
                                Padding="22,11"
                                SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Border x:Name="checkIcon"
                                        Width="18"
                                        Height="18"
                                        CornerRadius="4"
                                        Background="#22C55E"
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <TextBlock Text="✓"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               FontFamily="{StaticResource IRANSans}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,-1,0,0" />
                                </Border>

                                <TextBlock x:Name="txt"
                                           Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center"
                                           FontWeight="Medium"
                                           FontFamily="{StaticResource IRANSans}" />

                                <Border x:Name="countBorder"
                                        Background="#F1F5F9"
                                        CornerRadius="8"
                                        Padding="8,3"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="countText"
                                               Text="{TemplateBinding Tag}"
                                               FontSize="11"
                                               Foreground="#94A3B8"
                                               FontFamily="{StaticResource IRANSans}" />
                                </Border>

                                
                                <Border x:Name="separator"
                                        Width="1"
                                        Height="20"
                                        Background="#E2E8F0"
                                        Margin="22,0,0,0"
                                        VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="txt"
                                        Property="Foreground"
                                        Value="#1E40AF" />
                                <Setter TargetName="txt"
                                        Property="FontWeight"
                                        Value="Bold" />
                                <Setter TargetName="bd"
                                        Property="BorderBrush"
                                        Value="#3B82F6" />
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#F0F7FF" />
                                <Setter TargetName="countBorder"
                                        Property="Background"
                                        Value="#DBEAFE" />
                                <Setter TargetName="countText"
                                        Property="Foreground"
                                        Value="#2563EB" />
                                <Setter TargetName="checkIcon"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#F8FAFC" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked"
                                               Value="True" />
                                    <Condition Property="IsMouseOver"
                                               Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#E8F1FF" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border Margin="0,16"
            Background="White"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="0,12"
                    Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="16"
                                        Height="16"
                                        Source="/Assets/Icons/arrow-right_BLUE.svg"
                                        
                                        Margin="5,0,10,0" />
                        <TextBlock Text="اشخاص"
                                   FontSize="19"
                                   FontFamily="{StaticResource IRANSans}"
                                   FontWeight="Bold"
                                   Foreground="#001242"
                                   VerticalAlignment="Center" />

                        <Border >
                            
                            <Border Background="#ffffff"
                                    BorderBrush="#2563EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="10,10,0,10" 
                                    Width="300"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <svg:SvgViewbox Width="17"
                                                    Height="17"
                                                    Source="/Assets/Icons/search.svg"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,10,0" />

                                    <Grid>
                                        <TextBlock Text="جستجو"
                                                   FontSize="13"
                                                   Foreground="#737791"
                                                   FontFamily="{StaticResource IRANSans}"
                                                   FontWeight="Regular"
                                                   FlowDirection="RightToLeft"
                                                   VerticalAlignment="Center"
                                                   Padding="0,4"
                                                   IsHitTestVisible="False"
                                                   Panel.ZIndex="1">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}"
                                                                     Value="">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBox x:Name="SearchBox"
                                                 Width="250"
                                                 Height="32"
                                                 FontSize="13"
                                                 Foreground="#737791"
                                                 CaretBrush="#333333"
                                                 Background="#FFFFFF"
                                                 BorderThickness="0"
                                                 Padding="0,4"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FlowDirection="RightToLeft"
                                                 FontFamily="{StaticResource IRANSans}"
                                                 FontWeight="Regular"
                                                 TextAlignment="Left">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius"
                                                            Value="4" />
                                                </Style>
                                            </TextBox.Resources>
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderThickness="0"
                                                                        CornerRadius="4">
                                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                                  Focusable="False"
                                                                                  HorizontalScrollBarVisibility="Hidden"
                                                                                  VerticalScrollBarVisibility="Hidden" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="RightToLeft">

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnMore_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/MORE.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F5F7FA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnDelete_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/trash.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#FEF2F2" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnEdit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/EDIT.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers> 
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Width="36"
                                Height="36"
                                Margin="4,0,0,0"
                                Cursor="Hand"
                                Click="BtnNew_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Width="36"
                                            Height="36">
                                        <svg:SvgViewbox Width="18"
                                                        Height="18"
                                                        Source="/Assets/Icons/newdoc21.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0FFF4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            
            <Border Grid.Row="1"
                    BorderBrush="#D4E0FF"
                    BorderThickness="0,2,0,0"
                    Background="#FAFCFF"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal"
                            FlowDirection="RightToLeft"
                            VerticalAlignment="Center">

                    
                    <RadioButton x:Name="tabAll"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="PersonFilter"
                                 Content="همه اشخاص"
                                 Tag="۱۲۵ نفر"
                                 IsChecked="True"
                                 Checked="FilterTab_Checked" />

                    <RadioButton x:Name="tabCustomers"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="PersonFilter"
                                 Content="مشتریان"
                                 Tag="۱۰۰ نفر"
                                 Checked="FilterTab_Checked" />

                    <RadioButton x:Name="tabSuppliers"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="PersonFilter"
                                 Content="تامین کنندگان"
                                 Tag="۱۵ نفر"
                                 Checked="FilterTab_Checked" />

                    <RadioButton x:Name="tabPersonnel"
                                 Style="{StaticResource FilterTabStyle2}"
                                 GroupName="PersonFilter"
                                 Content="پرسنل و کارکنان"
                                 Tag="۱۰ نفر"
                                 Checked="FilterTab_Checked" />

                    


                    






                </StackPanel>
            </Border>


            
            
            
            <Border Grid.Row="2"
                    Background="Transparent"
                    ClipToBounds="False"
                    Padding="15,0">

                
                <Grid x:Name="DataGridContainer">

                    
                    <Grid.Resources>
                        
                        <Style x:Key="EllipseLeft"
                               TargetType="Ellipse">
                            <Setter Property="Width"
                                    Value="25" />
                            <Setter Property="Height"
                                    Value="35" />
                            <Setter Property="Fill"
                                    Value="#FFF8ED" />
                            <Setter Property="HorizontalAlignment"
                                    Value="Left" />
                            <Setter Property="VerticalAlignment"
                                    Value="Center" />
                            <Setter Property="Margin"
                                    Value="-31,0,0,0" />
                            <Setter Property="Panel.ZIndex"
                                    Value="-1" />
                        </Style>

                        
                        <Style x:Key="EllipseRight"
                               TargetType="Ellipse">
                            <Setter Property="Width"
                                    Value="25" />
                            <Setter Property="Height"
                                    Value="35" />
                            <Setter Property="Fill"
                                    Value="#FFF8ED" />
                            <Setter Property="HorizontalAlignment"
                                    Value="Right" />
                            <Setter Property="VerticalAlignment"
                                    Value="Center" />
                            <Setter Property="Margin"
                                    Value="0,0,-31,0" />
                            <Setter Property="Panel.ZIndex"
                                    Value="-1" />
                        </Style>
                    </Grid.Resources>

                    
                    <DataGrid x:Name="PersonsDataGrid"
                              CanUserSortColumns="False"
                              AutoGenerateColumns="False"
                              MinHeight="496"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              VerticalGridLinesBrush="#CCD0D9"
                              HorizontalGridLinesBrush="#CCD0D9"
                              RowHeight="30"
                              Background="White"
                              BorderBrush="#CCD0D9"
                              BorderThickness="1"
                              SnapsToDevicePixels="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              AlternationCount="2"
                              IsReadOnly="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              FontFamily="{StaticResource IRANSans}"
                              SelectionChanged="PersonsDataGrid_SelectionChanged">

                        <DataGrid.Resources>
                            
                            <Style x:Key="BaseTextColumnStyle"
                                   TargetType="TextBlock">
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                                <Setter Property="HorizontalAlignment"
                                        Value="Center" />
                                <Setter Property="VerticalAlignment"
                                        Value="Center" />
                                <Setter Property="Foreground"
                                        Value="#5C5C5C" />
                            </Style>

                            
                            <Style x:Key="LtrTextColumnStyle"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource BaseTextColumnStyle}">
                                <Setter Property="FlowDirection"
                                        Value="LeftToRight" />
                            </Style>

                            
                            <Style x:Key="RowNumberColumnStyle"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource BaseTextColumnStyle}">
                                <Setter Property="Foreground"
                                        Value="#94A3B8" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Style>

                            
                            <Style x:Key="FullNameColumnStyle"
                                   TargetType="TextBlock"
                                   BasedOn="{StaticResource BaseTextColumnStyle}">
                                <Setter Property="Foreground"
                                        Value="#5C5C5C" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </Style>

                            
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Tag"
                                        Value="True" />

                                <Setter Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#0D2159" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                                <Setter Property="FontFamily"
                                        Value="{StaticResource IRANSans}" />
                                <Setter Property="Padding"
                                        Value="10,0" />
                                <Setter Property="BorderBrush"
                                        Value="#BED1FF" />
                                <Setter Property="BorderThickness"
                                        Value="1,2,1,2" />
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center" />
                                <Setter Property="Height"
                                        Value="46" />

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <ContentPresenter Grid.Column="0"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center" />

                                                    <svg:SvgViewbox x:Name="FilterIcon"
                                                                    Width="13"
                                                                    Height="13"
                                                                    Grid.Column="1"
                                                                    Source="/Assets/Icons/filter-search.svg"
                                                                    VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Tag"
                                                         Value="False">
                                                    <Setter TargetName="FilterIcon"
                                                            Property="Visibility"
                                                            Value="Collapsed" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>



                            
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#5C5C5C" />
                                <Setter Property="FontSize"
                                        Value="12.5" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                                <Setter Property="Padding"
                                        Value="8,0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E8F2FF" />
                                        <Setter Property="Foreground"
                                                Value="#2667FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="Background"
                                        Value="#FFFFFF" />
                                <Setter Property="Cursor"
                                        Value="Hand" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex"
                                             Value="1">
                                        <Setter Property="Background"
                                                Value="#E5E7EC" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#F0F5FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E8F2FF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                        </DataGrid.Resources>

                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Width="50"
                                                Binding="{Binding RowNumberDisplay}"
                                                ElementStyle="{StaticResource RowNumberColumnStyle}">

                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>

                            </DataGridTextColumn>

                            <DataGridTextColumn Header="کد"
                                                Width="85"
                                                Binding="{Binding Code}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />
                            <DataGridTextColumn Header="دسته بندی"
                                                Width="120"
                                                Binding="{Binding Category}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />

                            <DataGridTemplateColumn Header="وضعیت"
                                                    Width="85">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,3"
                                                CornerRadius="5"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding StatusVisibility}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="غیرفعال">
                                                            <Setter Property="Background"
                                                                    Value="#FEE2E2" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}"
                                                                     Value="فعال">
                                                            <Setter Property="Background"
                                                                    Value="#DCFCE7" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       FontFamily="{StaticResource IRANSans}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="غیرفعال">
                                                                <Setter Property="Foreground"
                                                                        Value="#991B1B" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="فعال">
                                                                <Setter Property="Foreground"
                                                                        Value="#166534" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="نام مستعار"
                                                Width="110"
                                                Binding="{Binding Nickname}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />
                            <DataGridTextColumn Header="نام و نام خانوادگی"
                                                Width="160"
                                                Binding="{Binding FullName}"
                                                ElementStyle="{StaticResource FullNameColumnStyle}" />
                            <DataGridTextColumn Header="شرکت"
                                                Width="160"
                                                Binding="{Binding Company}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />
                            <DataGridTextColumn Header="استان"
                                                Width="100"
                                                Binding="{Binding Province}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />
                            <DataGridTextColumn Header="شهر"
                                                Width="85"
                                                Binding="{Binding City}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}" />
                            <DataGridTextColumn Header="تلفن"
                                                Width="120"
                                                Binding="{Binding Phone}"
                                                ElementStyle="{StaticResource LtrTextColumnStyle}">

                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>

                            </DataGridTextColumn>

                            <DataGridTextColumn Header="موبایل"
                                                Width="130"
                                                Binding="{Binding Mobile}"
                                                ElementStyle="{StaticResource LtrTextColumnStyle}">

                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>

                            </DataGridTextColumn>

                            <DataGridTextColumn Header="شناسه ملی"
                                                Width="130"
                                                Binding="{Binding NationalId}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}">

                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>

                            </DataGridTextColumn>

                            <DataGridTextColumn Header="شناسه اقتصادی"
                                                Width="130"
                                                Binding="{Binding EconomicId}"
                                                ElementStyle="{StaticResource BaseTextColumnStyle}">

                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>

                            </DataGridTextColumn>


                            <DataGridTemplateColumn Header="وضعیت حساب"
                                                    Width="110">

                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader"
                                           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Tag"
                                                Value="False" />
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>

                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,3"
                                                CornerRadius="10"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding AccountStatusVisibility}">

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="Transparent" />

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding AccountStatus}"
                                                                     Value="بدهکار">
                                                         
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding AccountStatus}"
                                                                     Value="بستانکار">
                                                          
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding AccountStatus}"
                                                                     Value="تسویه">
                                                          
                                                        </DataTrigger>

                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding AccountStatus}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       FontFamily="{StaticResource IRANSans}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                    <Border x:Name="LoadingOverlay"
                            Background="#B8F8FAFC"
                            Visibility="Collapsed"
                            Panel.ZIndex="30">

                        <Border Width="330"
                                Height="170"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="22"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FlowDirection="RightToLeft"
                                Opacity="0.98"
                                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform x:Name="LoaderCardScale"
                                                ScaleX="0.96"
                                                ScaleY="0.96" />
                            </Border.RenderTransform>

                            <Border.Effect>
                                <DropShadowEffect Color="#2563EB"
                                                  BlurRadius="32"
                                                  ShadowDepth="0"
                                                  Opacity="0.14" />
                            </Border.Effect>

                            <Grid Margin="28,22">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Icon / Modern Loading Mark -->
                                <Grid Grid.Row="0"
                                      Width="58"
                                      Height="42"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,14">

                                    <Border Background="#F1F5FF"
                                            CornerRadius="14" />

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FlowDirection="LeftToRight">

                                        <Border Width="7"
                                                Height="20"
                                                CornerRadius="4"
                                                Background="#2563EB"
                                                Margin="3,0">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="BarOneScale"
                                                                ScaleY="0.45"
                                                                CenterY="10" />
                                            </Border.RenderTransform>
                                        </Border>

                                        <Border Width="7"
                                                Height="20"
                                                CornerRadius="4"
                                                Background="#3B82F6"
                                                Margin="3,0">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="BarTwoScale"
                                                                ScaleY="0.75"
                                                                CenterY="10" />
                                            </Border.RenderTransform>
                                        </Border>

                                        <Border Width="7"
                                                Height="20"
                                                CornerRadius="4"
                                                Background="#60A5FA"
                                                Margin="3,0">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="BarThreeScale"
                                                                ScaleY="0.45"
                                                                CenterY="10" />
                                            </Border.RenderTransform>
                                        </Border>

                                    </StackPanel>
                                </Grid>

                                <!-- Main Text -->
                                <TextBlock Grid.Row="1"
                                           Text="در حال بارگذاری اطلاعات"
                                           FontFamily="{StaticResource IRANSans}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#001242"
                                           HorizontalAlignment="Center" />

                                <TextBlock Grid.Row="2"
                                           Text="لطفاً چند لحظه صبر کنید..."
                                           FontFamily="{StaticResource IRANSans}"
                                           FontSize="12.5"
                                           Foreground="#64748B"
                                           Margin="0,7,0,16"
                                           HorizontalAlignment="Center" />

                                <!-- Minimal Moving Progress -->
                                <Border Grid.Row="3"
                                        Width="210"
                                        Height="6"
                                        CornerRadius="6"
                                        Background="#EEF4FF"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center">

                                    <Border Width="74"
                                            Height="6"
                                            CornerRadius="6"
                                            HorizontalAlignment="Left">

                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                                 EndPoint="1,0">
                                                <GradientStop Color="#93C5FD"
                                                              Offset="0" />
                                                <GradientStop Color="#2563EB"
                                                              Offset="0.5" />
                                                <GradientStop Color="#93C5FD"
                                                              Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ProgressMove"
                                                                X="-80" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Border>

                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Grid.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">

                                                <!-- Card soft breathing -->
                                                <DoubleAnimation Storyboard.TargetName="LoaderCardScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 From="0.96"
                                                                 To="1"
                                                                 Duration="0:0:0.55"
                                                                 AutoReverse="True" />

                                                <DoubleAnimation Storyboard.TargetName="LoaderCardScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 From="0.96"
                                                                 To="1"
                                                                 Duration="0:0:0.55"
                                                                 AutoReverse="True" />

                                                <!-- Equalizer animation -->
                                                <DoubleAnimation Storyboard.TargetName="BarOneScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 From="0.45"
                                                                 To="1"
                                                                 Duration="0:0:0.45"
                                                                 AutoReverse="True" />

                                                <DoubleAnimation Storyboard.TargetName="BarTwoScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 From="0.75"
                                                                 To="0.35"
                                                                 Duration="0:0:0.45"
                                                                 BeginTime="0:0:0.12"
                                                                 AutoReverse="True" />

                                                <DoubleAnimation Storyboard.TargetName="BarThreeScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 From="0.45"
                                                                 To="1"
                                                                 Duration="0:0:0.45"
                                                                 BeginTime="0:0:0.24"
                                                                 AutoReverse="True" />

                                                <!-- Moving progress highlight -->
                                                <DoubleAnimation Storyboard.TargetName="ProgressMove"
                                                                 Storyboard.TargetProperty="X"
                                                                 From="-80"
                                                                 To="220"
                                                                 Duration="0:0:1.25" />

                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>

                            </Grid>
                        </Border>
                    </Border>
                    <Ellipse Style="{StaticResource EllipseLeft}" />

                    
                    <Ellipse Style="{StaticResource EllipseRight}" />

                </Grid>
            </Border>







            
            <Border Grid.Row="3"
                    Padding="5,14"
                    Background="White"
                    BorderBrush="#E9F0FF"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                  

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                FlowDirection="LeftToRight">

                        <Button Width="34"
                                Height="34"
                                Margin="0,0,2,0"
                                Cursor="Hand"
                                Click="BtnPrevPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30"
                                            Background="Transparent">
                                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                                        Width="30"
                                                        Height="30"
                                                        Source="/Assets/Icons/Leftsquare.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>


                        <ItemsControl x:Name="PageButtonsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="32"
                                            Height="32"
                                            Cursor="Hand"
                                            Click="BtnPage_Click"
                                            Tag="{Binding PageNumber}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd"
                                                        Background="Transparent"
                                                        CornerRadius="6">
                                                    <TextBlock Text="{Binding PageNumberDisplay}"
                                                               FontSize="13"
                                                               FontFamily="{StaticResource IRANSans}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground"
                                                                        Value="#94A3B8" />
                                                                <Setter Property="FontWeight"
                                                                        Value="Normal" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrent}"
                                                                                 Value="True">
                                                                        <Setter Property="Foreground"
                                                                                Value="#001242" />
                                                                        <Setter Property="FontWeight"
                                                                                Value="Bold" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="bd"
                                                                Property="Background"
                                                                Value="#F5F7FA" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>


                        <Button Width="34"
                                Height="34"
                                Margin="2,0,0,0"
                                Cursor="Hand"
                                Click="BtnNextPage_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Width="30"
                                            Height="30"
                                            Background="Transparent">
                                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                                        Width="30"
                                                        Height="30"
                                                        Source="/Assets/Icons/Rightsquare.svg" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="bd"
                                                    Property="Background"
                                                    Value="#F0F5FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>