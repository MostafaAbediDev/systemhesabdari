<UserControl x:Class="Taadol.Views.FinancialPeriodListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Taadol.Controls"
             FlowDirection="RightToLeft"
             Background="#F6F8FC">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                Padding="15"
                BorderBrush="#E9F0FF"
                BorderThickness="0,0,0,1">

            <Grid>

                <TextBlock Text="دوره‌های مالی"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="#001242" />

                <controls:IconButton ButtonText="دوره جدید"
                                     IconSource="/Assets/Icons/add.svg"
                                     ButtonBackground="#2667FF"
                                     HorizontalAlignment="Left"
                                     ButtonCommand="{Binding CreateCommand}" />
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1"
              Margin="15">

            <Border Background="White"
                    BorderBrush="#E9F0FF"
                    BorderThickness="1"
                    CornerRadius="10">

                <Grid>

                    <!-- LOADING -->
                    <Grid x:Name="LoadingOverlay"
                          Background="#80FFFFFF"
                          Visibility="Collapsed"
                          Panel.ZIndex="10">

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <ProgressBar Width="180"
                                         Height="6"
                                         IsIndeterminate="True" />

                            <TextBlock Text="در حال دریافت اطلاعات..."
                                       Margin="0,10,0,0"
                                       Foreground="#2667FF"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- TABLE -->
                    <DataGrid ItemsSource="{Binding Items}"
                              AutoGenerateColumns="False"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="عنوان دوره"
                                                Binding="{Binding Title}" />

                            <DataGridTextColumn Header="سال"
                                                Binding="{Binding Year}" />

                            <DataGridTextColumn Header="شروع"
                                                Binding="{Binding StartDate}" />

                            <DataGridTextColumn Header="پایان"
                                                Binding="{Binding EndDate}" />

                            <DataGridTemplateColumn Header="وضعیت">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <controls:ToggleSwitchControl FirstLabel="فعال"
                                                                      SecondLabel="غیرفعال"
                                                                      IsFirstSelected="{Binding IsActive}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>
            </Border>
        </Grid>

        <!-- PAGINATION -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E9F0FF"
                BorderThickness="0,1,0,0"
                Padding="10">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">

                <Button Content="قبلی"
                        Width="80"
                        Margin="5"
                        Command="{Binding PrevPageCommand}" />

                <ItemsControl ItemsSource="{Binding Pages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Width="32"
                                    Margin="3"
                                    Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="بعدی"
                        Width="80"
                        Margin="5"
                        Command="{Binding NextPageCommand}" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>