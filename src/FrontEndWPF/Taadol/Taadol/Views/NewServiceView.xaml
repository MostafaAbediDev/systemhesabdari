
<UserControl x:Class="Taadol.Views.NewServiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             xmlns:controls="clr-namespace:Taadol.Controls"
             FlowDirection="RightToLeft"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Border CornerRadius="12"
                ClipToBounds="True"
                Background="#ffffff"
           
                Margin="24,0">
            <StackPanel>

                
                <Grid Margin="10,15,10,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="16"
                                        Height="16"
                                        Source="/Assets/Icons/arrow-right.svg"
                                        Margin="10,0,10,0" />
                        <TextBlock Text="مشخصات خدمات جدید"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource IRANSans}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">

                        <controls:CustomOutlinedButton Margin="0,0,12,0"
                                                       Text="ثبت موقت">
                            <controls:CustomOutlinedButton.Icon>
                                <svg:SvgViewbox  Source="/Assets/Icons/tempsave.svg"
                                                 Width="16"
                                                 Height="16" />
                            </controls:CustomOutlinedButton.Icon>
                        </controls:CustomOutlinedButton>

                        <controls:IconButton ButtonText="ثبت"
                                             IconSource="/Assets/Icons/save.svg"
                                             ButtonCommand="{Binding EditCommand}"
                                             ButtonBackground="#2667FF" />

                    </StackPanel>
                </Grid>

                
                <Border Height="1"
                        Margin="7,0,7,2">
                    <Border.Background>
                        <VisualBrush TileMode="Tile"
                                     Viewport="0,0,10,1"
                                     ViewportUnits="Absolute"
                                     Viewbox="0,0,10,1"
                                     ViewboxUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="10"
                                      Height="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="5" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Fill="#D4E0FF" />
                                    <Rectangle Grid.Column="1"
                                               Fill="#D4E0FF" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>

                
                <Border Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Margin="0,0,24,0">

                            
                            <TextBlock Text="کد حسابداری"
                                       Style="{StaticResource FormLabel}" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <controls:ModernPersianTextBox Grid.Column="0"
                                                               Text="{Binding Username}"
                                                               Placeholder="1234" />

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <controls:ToggleSwitchControl FirstLabel="اتوماتیک"
                                                                  SecondLabel="دستی"
                                                                  IsFirstSelected="True"
                                                                  Grid.Column="1" />
                                </StackPanel>

                                <ToggleButton Content="آیا این خدمات فعال است؟"
                                              FlowDirection="LeftToRight"
                                              Style="{StaticResource StatusToggleButton}"
                                              IsChecked="True"
                                              Grid.Column="2"
                                              Margin="10,0,18,0" />
                            </Grid>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.65*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="0.35*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Grid.ColumnSpan="2">
                                    <TextBlock Text="نام خدمات"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Placeholder="بنویسید"
                                                                   HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.5*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="0.5*" />
                                    <ColumnDefinition Width="0.5*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="کد خدمات"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Placeholder="1234" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="بارکد"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Placeholder="1234" />
                                    <TextBlock FontSize="12"
                                               FontFamily="{StaticResource IRANSans}"
                                               Foreground="#001242">
            <Run Text="بارکدهای مختلف را با " />
            <Run Text=";"
                                        FontSize="14"
                                        Foreground="#00D86F" />
            <Run Text=" از هم جدا کنید." />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>


                            
                            <Grid Margin="0,0,0,8"
                                  HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="234*" />
                                    <ColumnDefinition Width="81" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="440*" />
                                </Grid.ColumnDefinitions>
                              
                                <StackPanel Grid.Column="0"
                                            Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock Text="دسته کالا"
                                                   Style="{StaticResource FormLabel}" />

                                        <Button Style="{StaticResource LightAddButton}"
                                                Width="30"
                                                Margin="10,0,0,4"
                                                Background="#E9F0FF"
                                                BorderBrush="Transparent"
                                                Height="30">


                                            <StackPanel Orientation="Horizontal">
                                                <svg:SvgViewbox Width="13"
                                                                Height="13"
                                                                Source="/Assets/Icons/add-square.svg"
                                                                VerticalAlignment="Center" />

                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="158" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Style="{StaticResource SearchableComboBox}"
                                                  Tag="جستجو..."
                                                  Margin="0,0,0,0"
                                                  Width="315"
                                                  ItemContainerStyle="{StaticResource SearchableComboBoxItem}"
                                                 
                                                  Grid.ColumnSpan="2">
                                            <ComboBoxItem Content="گزینه ۱" />
                                            <ComboBoxItem Content="گزینه ۲" />
                                            <ComboBoxItem Content="گزینه ۳" />
                                        </ComboBox>

                                        <!--<Button Grid.Column="1"
                       Style="{StaticResource LightAddButton}"
                       Width="115"
                       Margin="10,0,0,0"
                       Background="#E9F0FF"
                       BorderBrush="Transparent"
                       Height="42">


                   <StackPanel Orientation="Horizontal">
                       <svg:SvgViewbox Width="13"
                                       Height="13"
                                       Source="/Assets/Icons/add-square.svg"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                       <TextBlock Text="دسته جدید"
                                  FontWeight="Medium"
                                  FontSize="14"
                                  Foreground="#5185FF"
                                  FontFamily="{StaticResource IRANSans}"
                                  VerticalAlignment="Center" />
                   </StackPanel>
               </Button>-->
                                    </Grid>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,4,0,0">



                                    </StackPanel>
                                </StackPanel>

                              



                            </Grid>

                            
                            <TextBlock Text="توضیحات"
                                       Style="{StaticResource FormLabel}" />
                            <controls:ModernPersianTextBox Grid.Column="0"
                                                           Text="{Binding Username}"
                                                           Placeholder="1234" />
                        </StackPanel>

                        
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,0,5,0">

                            <controls:ImagePickerControl PlaceholderIconSource="/Assets/Icons/box-add.svg"
                                                         AddLabel="انتخاب تصویر"
                                                         RemoveLabel="حذف"
                                                         ImagePath="{Binding ProductImage, Mode=TwoWay}"
                                                         ImageSelected="OnImageSelected"
                                                         ImageRemoved="OnImageRemoved" />
                        </StackPanel>
                    </Grid>
                </Border>

                
                <Grid Margin="0,2,0,5">
                    <Border Height="3">
                        <Border.Background>
                            <VisualBrush TileMode="Tile"
                                         Viewport="0,0,10,1"
                                         ViewportUnits="Absolute"
                                         Viewbox="0,0,10,1"
                                         ViewboxUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Grid Width="10"
                                          Height="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="5" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0"
                                                   Fill="#BED1FF" />
                                        <Rectangle Grid.Column="1"
                                                   Fill="Transparent" />
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.Background>
                    </Border>

                    <Ellipse Width="17"
                             Margin="-9,0,0,0"
                             Height="25"
                             Fill="#FFF8ED"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Panel.ZIndex="2" />

                    <Ellipse Width="17"
                             Height="25"
                             Margin="0,0,-9,0"
                             Fill="#FFF8ED"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Panel.ZIndex="2" />
                </Grid>

                
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>

                        
                        <Border CornerRadius="12"
                                BorderThickness="1.5"
                                BorderBrush="#BED1FF"
                                Background="#F8FAFF"
                                Padding="4"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="قیمت دهی"
                                              Style="{StaticResource ModernTabButton}"
                                              Margin="10,0,6,0"
                                              x:Name="TabPricing"
                                              IsChecked="True"
                                              Checked="TabPricing_Checked" />
                                <RadioButton Content="مالیات"
                                              Style="{StaticResource ModernTabButton}"
                                              x:Name="TabTax"
                                              Margin="10,0,10,0"
                                              Checked="TabTax_Checked" />
                            </StackPanel>
                        </Border>

                        
                        <StackPanel x:Name="PricingContent"
                                    Visibility="Visible">

                            
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="مبلغ دستمزد"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Suffix="ریال"
                                                                   Width="225"
                                                                   Placeholder="1234" />
                                </StackPanel>

                                <ToggleButton Content="مدیریت لیست قیمت"
                                              FlowDirection="LeftToRight"
                                              Style="{StaticResource StatusToggleButton}"
                                              IsChecked="True"
                                              Grid.Column="1"
                                              Margin="10,25,18,0" />
                            </Grid>

                            
                            <Grid Margin="0,0,0,8">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="IsEnabled"
                                                Value="False" />
                                        <Setter Property="Opacity"
                                                Value="0.5" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=PriceListCheckBox}"
                                                         Value="True">
                                                <Setter Property="IsEnabled"
                                                        Value="True" />
                                                <Setter Property="Opacity"
                                                        Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="قیمت همکار"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Suffix="ریال"
                                                                   Width="225"
                                                                   Placeholder="1234" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="قیمت پرسنل"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Suffix="ریال"
                                                                   Width="225"
                                                                   Placeholder="1234" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        
                        <StackPanel x:Name="TaxContent"
                                    Visibility="Collapsed"     >

                            
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Left"
                                        FlowDirection="LeftToRight">
                                <ToggleButton Content="مشمول مالیات فروش"
                                              FlowDirection="LeftToRight"
                                              Style="{StaticResource StatusToggleButton}"
                                              IsChecked="True"
                                              Margin="10,0,18,0" />
                            </StackPanel>

                            
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="IsEnabled"
                                                Value="False" />
                                        <Setter Property="Opacity"
                                                Value="0.5" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=SalesTaxCheckBox}"
                                                         Value="True">
                                                <Setter Property="IsEnabled"
                                                        Value="True" />
                                                <Setter Property="Opacity"
                                                        Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock Text="مالیات فروش"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding Username}"
                                                                   Suffix="ریال"
                                                                   Width="225"
                                                                   Placeholder="1234" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>