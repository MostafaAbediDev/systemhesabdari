<UserControl x:Class="Taadol.Views.NewCompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Border CornerRadius="12"
                ClipToBounds="True"
                Background="#ffffff"
                Margin="24,0">
            <StackPanel>

                
                <Grid Margin="10,15,10,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Width="14"
                                        Height="14"
                                        Source="/Assets/Icons/arrow-right.svg"
                                        Margin="10,0,10,0" />
                        <TextBlock Text="اطلاعات شرکت"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource IRANSans}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <controls:CustomOutlinedButton Margin="0,0,12,0"
                                                       Text="ثبت موقت">
                            <controls:CustomOutlinedButton.Icon>
                                <svg:SvgViewbox Source="/Assets/Icons/tempsave.svg"
                                                Width="16"
                                                Height="16" />
                            </controls:CustomOutlinedButton.Icon>
                        </controls:CustomOutlinedButton>

                        <controls:IconButton ButtonText="ثبت"
                                             IconSource="/Assets/Icons/save.svg"
                                             ButtonCommand="{Binding SaveCommand}"
                                             ButtonBackground="#2667FF" />
                    </StackPanel>
                </Grid>

                
                <Border Height="1"
                        Margin="7,0,7,2">
                    <Border.Background>
                        <VisualBrush TileMode="Tile"
                                     Viewport="0,0,10,1"
                                     ViewportUnits="Absolute"
                                     Viewbox="0,0,10,1"
                                     ViewboxUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="10"
                                      Height="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="5" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0"
                                               Fill="#D4E0FF" />
                                    <Rectangle Grid.Column="1"
                                               Fill="Transparent" />
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>

                
                <Border Style="{StaticResource CardPanel}">
                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            
                            <StackPanel Grid.Row="0"
                                        Margin="0,0,0,16">
                                <TextBlock Text="شناسه یکتا"
                                           Style="{StaticResource FormLabel}" />
                                <StackPanel Orientation="Horizontal">
                                    <controls:ModernPersianTextBox Width="200"
                                                                   Text="{Binding UniqueId, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="۱۲۳۴" />
                                    <controls:ToggleSwitchControl Margin="12,0,0,0"
                                                                  FirstLabel="اتوماتیک"
                                                                  SecondLabel="دستی"
                                                                  IsFirstSelected="True"
                                                                  SelectionChanged="UniqueIdToggle_SelectionChanged" />
                                </StackPanel>
                            </StackPanel>

                            
                            <Grid Grid.Row="1"
                                  Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="TextCol" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="نام شرکت / کسب و کار"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="ایران خودرو" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,0,4">
                                    <ToggleButton Content=".شعبه فعال است"
                                                  FlowDirection="LeftToRight"
                                                  Style="{StaticResource StatusToggleButton}"
                                                  IsChecked="{Binding IsBranchActive}" />
                                </StackPanel>
                            </Grid>

                            
                            <Grid Grid.Row="2"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="TextCol" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="نام رسمی ثبتی"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:ModernPersianTextBox Text="{Binding OfficialName, UpdateSourceTrigger=PropertyChanged}"
                                                                   Placeholder="ایران خودرو" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="تاریخ تاسیس"
                                               Style="{StaticResource FormLabel}" />
                                    <controls:PersianDatePickerControl x:Name="FoundingDatePicker"
                                                                       SelectedDate="{Binding FoundingDate}"
                                                                       DateChanged="DatePicker_DateChanged" />
                                </StackPanel>
                            </Grid>

                        </Grid>

                        
                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Center">
                            <controls:ImagePickerControl PlaceholderIconSource="/Assets/Icons/Scale.svg"
                                                         AddLabel="انتخاب تصویر"
                                                         RemoveLabel="حذف"
                                                         ImagePath="{Binding ProductImage, Mode=TwoWay}"
                                                         ImageSelected="OnImageSelected"
                                                         ImageRemoved="OnImageRemoved" />
                        </StackPanel>

                    </Grid>
                </Border>

                
                <Grid Margin="0,2,0,5">
                    <Ellipse Width="17"
                             Margin="-9,0,0,0"
                             Height="25"
                             Fill="#FFF8ED"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Panel.ZIndex="2" />
                    <Ellipse Width="17"
                             Height="25"
                             Margin="0,0,-9,0"
                             Fill="#FFF8ED"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Panel.ZIndex="2" />
                </Grid>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
