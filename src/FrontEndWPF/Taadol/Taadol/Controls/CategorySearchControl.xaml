<UserControl x:Class="Taadol.Controls.CategorySearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             x:Name="RootControl">

    <UserControl.Resources>

        <!-- ==================== استایل سطح اول ==================== -->
        <Style x:Key="RootTreeViewItemStyle"
               TargetType="TreeViewItem">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="2" />
            <Setter Property="Margin"
                    Value="0,2,0,2" />
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#0D2159" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd"
                                    CornerRadius="8"
                                    Margin="4,2,4,2"
                                    Padding="10,8">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BdBrush"
                                                     Color="Transparent" />
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- آیکون باز/بسته -->
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Width="20"
                                                  Height="20"
                                                  Visibility="Collapsed">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <svg:SvgViewbox x:Name="ArrowIcon"
                                                                    Width="10"
                                                                    Height="10"
                                                                    Source="/Assets/Icons/ArrowLeft.svg"
                                                                    RenderTransformOrigin="0.5,0.5">
                                                        <svg:SvgViewbox.RenderTransform>
                                                            <RotateTransform x:Name="ArrowRot"
                                                                             Angle="180" />
                                                        </svg:SvgViewbox.RenderTransform>
                                                    </svg:SvgViewbox>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked"
                                                             Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ArrowRot"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     To="270"
                                                                                     Duration="0:0:0.55">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseInOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ArrowRot"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     To="180"
                                                                                     Duration="0:0:0.55">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseInOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <!-- نقطه -->
                                    <Border x:Name="Dot"
                                            Grid.Column="0"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Margin="6,0,16,0"
                                            Visibility="Collapsed">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="DotBrush"
                                                             Color="#2667FF" />
                                        </Border.Background>
                                    </Border>

                                    <!-- محتوا -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal">
                                        <svg:SvgViewbox x:Name="ItemIcon"
                                                        Width="20"
                                                        Height="20"
                                                        Margin="0,0,6,0"
                                                        VerticalAlignment="Center" />
                                        <ContentPresenter x:Name="PART_Header"
                                                          Content="{TemplateBinding Header}"
                                                          VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- دکمه‌های عملیاتی - hover توسط code-behind کنترل میشه -->
                                    <StackPanel x:Name="ActionButtons"
                                                Grid.Column="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                Margin="5,0,0,0"
                                                Opacity="0">

                                        <Border x:Name="AddButton"
                                                Width="28"
                                                Height="28"
                                                CornerRadius="6"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="AddButton_Click"
                                                ToolTip="اضافه کردن زیرمجموعه">
                                            <svg:SvgViewbox Width="14"
                                                            Height="14"
                                                            Source="/Assets/Icons/Plus.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#E9F0FF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border x:Name="EditButton"
                                                Width="28"
                                                Height="28"
                                                CornerRadius="6"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="EditButton_Click"
                                                ToolTip="ویرایش">
                                            <svg:SvgViewbox Width="14"
                                                            Height="14"
                                                            Source="/Assets/Icons/edit.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#E9F0FF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border x:Name="trashButton"
                                                Width="28"
                                                Height="28"
                                                CornerRadius="6"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="DeleteButton_Click"
                                                ToolTip="حذف">
                                            <svg:SvgViewbox Width="14"
                                                            Height="14"
                                                            Source="/Assets/Icons/trash.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#FFE5E5" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="24,0,0,0"
                                            Opacity="0">
                                <ItemsPresenter.LayoutTransform>
                                    <ScaleTransform x:Name="ItemsScale"
                                                    ScaleY="0" />
                                </ItemsPresenter.LayoutTransform>
                            </ItemsPresenter>
                            <Border x:Name="SeparatorLine"
                                    Height="1"
                                    Background="#E9F0FF"
                                    Margin="10,4,10,4" />
                        </StackPanel>

                        <ControlTemplate.Triggers>

                            <Trigger Property="HasItems"
                                     Value="True">
                                <Setter TargetName="Expander"
                                        Property="Visibility"
                                        Value="Visible" />
                                <Setter TargetName="Dot"
                                        Property="Visibility"
                                        Value="Collapsed" />
                                <Setter TargetName="AddButton"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>

                            <Trigger Property="HasItems"
                                     Value="False">
                                <Setter TargetName="Expander"
                                        Property="Visibility"
                                        Value="Collapsed" />
                                <Setter TargetName="Dot"
                                        Property="Visibility"
                                        Value="Visible" />
                                <Setter TargetName="AddButton"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>


                            <Trigger Property="IsExpanded"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemsScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="0"
                                                             To="1"
                                                             Duration="0:0:0.28">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemsHost"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemsHost"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemsScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- انتخاب‌شده -->
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#2667FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== استایل سطح دوم ==================== -->
        <Style x:Key="ChildTreeViewItemStyle"
               TargetType="TreeViewItem">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="2" />
            <Setter Property="Margin"
                    Value="0,1,0,1" />
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Foreground"
                    Value="#2A3547" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd"
                                    CornerRadius="6"
                                    Margin="4,1,4,1"
                                    Padding="8,6">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BdBrush"
                                                     Color="Transparent" />
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Width="20"
                                                  Height="20"
                                                  Margin="0,0,12,0"
                                                  VerticalAlignment="Center"
                                                  Visibility="Collapsed">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <svg:SvgViewbox x:Name="ArrowIcon"
                                                                    Width="10"
                                                                    Height="10"
                                                                    Source="/Assets/Icons/ArrowLeft.svg"
                                                                    RenderTransformOrigin="0.5,0.5">
                                                        <svg:SvgViewbox.RenderTransform>
                                                            <RotateTransform x:Name="ArrowRot"
                                                                             Angle="180" />
                                                        </svg:SvgViewbox.RenderTransform>
                                                    </svg:SvgViewbox>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked"
                                                             Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ArrowRot"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     To="270"
                                                                                     Duration="0:0:0.55">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseInOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ArrowRot"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     To="180"
                                                                                     Duration="0:0:0.55">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseInOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <Border x:Name="Dot"
                                            Grid.Column="0"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Margin="6,0,10,0"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="DotBrush"
                                                             Color="#2667FF" />
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal">
                                        <svg:SvgViewbox x:Name="ItemIcon"
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center" />
                                        <ContentPresenter x:Name="PART_Header"
                                                          Content="{TemplateBinding Header}"
                                                          VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel x:Name="ActionButtons"
                                                Grid.Column="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                Opacity="0"
                                                Margin="5,0,0,0">

                                        <Border x:Name="AddButton"
                                                Width="24"
                                                Height="24"
                                                CornerRadius="5"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="AddButton_Click"
                                                ToolTip="اضافه کردن زیرمجموعه">
                                            <svg:SvgViewbox Width="12"
                                                            Height="12"
                                                            Source="/Assets/Icons/Plus.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#E9F0FF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border x:Name="EditButton"
                                                Width="24"
                                                Height="24"
                                                CornerRadius="5"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="EditButton_Click"
                                                ToolTip="ویرایش">
                                            <svg:SvgViewbox Width="12"
                                                            Height="12"
                                                            Source="/Assets/Icons/edit.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#E9F0FF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border x:Name="trashButton"
                                                Width="24"
                                                Height="24"
                                                CornerRadius="5"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="DeleteButton_Click"
                                                ToolTip="حذف">
                                            <svg:SvgViewbox Width="12"
                                                            Height="12"
                                                            Source="/Assets/Icons/trash.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#FFE5E5" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="24,0,0,0"
                                            Opacity="0">
                                <ItemsPresenter.LayoutTransform>
                                    <ScaleTransform x:Name="ItemsScale"
                                                    ScaleY="0" />
                                </ItemsPresenter.LayoutTransform>
                            </ItemsPresenter>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems"
                                     Value="True">
                                <Setter TargetName="Expander"
                                        Property="Visibility"
                                        Value="Visible" />
                                <Setter TargetName="Dot"
                                        Property="Visibility"
                                        Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems"
                                     Value="False">
                                <Setter TargetName="Expander"
                                        Property="Visibility"
                                        Value="Collapsed" />
                                <Setter TargetName="Dot"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsExpanded"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemsScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="0"
                                                             To="1"
                                                             Duration="0:0:0.28">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemsHost"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ItemsHost"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ItemsScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#2667FF" />
                                <Setter TargetName="Dot"
                                        Property="Background"
                                        Value="#2667FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==================== استایل سطح سوم ==================== -->
        <Style x:Key="GrandChildTreeViewItemStyle"
               TargetType="TreeViewItem">
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="2" />
            <Setter Property="Margin"
                    Value="0,1,0,1" />
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="FontWeight"
                    Value="Normal" />
            <Setter Property="Foreground"
                    Value="#2A3547" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd"
                                    CornerRadius="6"
                                    Margin="4,1,4,1"
                                    Padding="8,6">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BdBrush"
                                                     Color="Transparent" />
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="Dot"
                                            Grid.Column="0"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Margin="6,0,10,0"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="DotBrush"
                                                             Color="#C0D0F4" />
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal">
                                        <ContentPresenter x:Name="PART_Header"
                                                          Content="{TemplateBinding Header}"
                                                          VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel x:Name="ActionButtons"
                                                Grid.Column="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                Opacity="0"
                                                Margin="5,0,0,0">

                                        <Border x:Name="EditButton"
                                                Width="24"
                                                Height="24"
                                                CornerRadius="5"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="EditButton_Click"
                                                ToolTip="ویرایش">
                                            <svg:SvgViewbox Width="12"
                                                            Height="12"
                                                            Source="/Assets/Icons/edit.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#E9F0FF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border x:Name="trashButton"
                                                Width="24"
                                                Height="24"
                                                CornerRadius="5"
                                                Margin="2,0"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonUp="DeleteButton_Click"
                                                ToolTip="حذف">
                                            <svg:SvgViewbox Width="12"
                                                            Height="12"
                                                            Source="/Assets/Icons/trash.svg"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#FFE5E5" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="24,0,0,0"
                                            Opacity="0">
                                <ItemsPresenter.LayoutTransform>
                                    <ScaleTransform x:Name="ItemsScale"
                                                    ScaleY="0" />
                                </ItemsPresenter.LayoutTransform>
                            </ItemsPresenter>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#2667FF" />
                                <Setter TargetName="Dot"
                                        Property="Background"
                                        Value="#2667FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,5" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding HeaderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource FormLabel}"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Style="{StaticResource LightAddButton}"
                    Width="35"
                    Height="35"
                    Background="#E9F0FF"
                    BorderBrush="Transparent"
                    Click="AddRootButton_Click">
                <svg:SvgViewbox Width="13"
                                Height="13"
                                Source="/Assets/Icons/add-square.svg"
                                VerticalAlignment="Center" />
            </Button>
        </Grid>

        <Border Background="White"
                Grid.Row="1"
                CornerRadius="12"
                BorderBrush="#D4E1FF"
                BorderThickness="1"
                Cursor="Hand"
                x:Name="MainBorder"
                MouseLeftButtonUp="MainBorder_MouseLeftButtonUp">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="36"
                        Height="36"
                        Margin="4,4,8,4"
                        CornerRadius="10"
                        Background="#F0F5FF">
                    <svg:SvgViewbox x:Name="MainIcon"
                                    Width="20"
                                    Height="20"
                                    Source="/Assets/Icons/profile_u.svg"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="SelectedText"
                           Grid.Column="1"
                           Text="یک دسته جستجو کنید..."
                           FontSize="13"
                           Foreground="#737791"
                           FontFamily="{StaticResource IRANSans}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left" />

                <Border Grid.Column="2"
                        Width="32"
                        Height="32"
                        Margin="0,0,4,0"
                        CornerRadius="8">
                    <svg:SvgViewbox x:Name="ArrowIcon"
                                    Width="12"
                                    Height="12"
                                    Source="/Assets/Icons/Arrow.svg"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                        <svg:SvgViewbox.RenderTransform>
                            <RotateTransform x:Name="ArrowRotation"
                                             Angle="0" />
                        </svg:SvgViewbox.RenderTransform>
                    </svg:SvgViewbox>
                </Border>
            </Grid>
        </Border>

        <Popup x:Name="SearchPopup"
               PlacementTarget="{Binding ElementName=MainBorder}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               Closed="Popup_Closed"
               Width="{Binding ActualWidth, ElementName=MainBorder}">

            <Border x:Name="PopupContainer"
                    Background="White"
                    BorderBrush="#D4E1FF"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxHeight="450"
                    Margin="0,4,0,0"
                    RenderTransformOrigin="0.5,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16"
                                      ShadowDepth="2"
                                      Opacity="0.15"
                                      Color="#001242"
                                      Direction="270" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="PopupSlide"
                                        Y="-10" />
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F8FAFF"
                            CornerRadius="12,12,0,0"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <svg:SvgViewbox Grid.Column="0"
                                            Width="18"
                                            Height="18"
                                            Source="/Assets/Icons/search.svg"
                                            Margin="0,0,10,0" />
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     TextChanged="SearchBox_TextChanged"
                                     FontFamily="{StaticResource IRANSans}"
                                     FontSize="13"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#0D2159" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Height="1"
                            Background="#E9F0FF" />

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CategoryTree"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  SelectedItemChanged="CategoryTree_SelectedItemChanged"
                                  Padding="8,8,8,8" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
