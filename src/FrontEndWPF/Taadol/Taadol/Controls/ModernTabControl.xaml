<UserControl x:Class="Taadol.Controls.ModernTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ModernTabButton"
               TargetType="RadioButton">
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontWeight"
                    Value="Medium" />
            <Setter Property="Foreground"
                    Value="#001242" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#D4E0FF" />
            <Setter Property="Height"
                    Value="44" />
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Padding"
                    Value="24,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="Transparent" />
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#2667FF" />
                                <Setter Property="Foreground"
                                        Value="#2667FF" />
                            </Trigger>

                            <Trigger Property="IsChecked"
                                     Value="False">
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#555555" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <Border CornerRadius="12"
                    BorderThickness="1.5"
                    BorderBrush="#BED1FF"
                    Background="#F8FAFF"
                    Padding="4"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="تماس و آدرس"
                                 Style="{StaticResource ModernTabButton}"
                                 Margin="10,0,6,0"
                                 IsChecked="True"
                                 GroupName="ModernTabs"
                                 x:Name="TabPricing"
                                 Checked="TabPricing_Checked" />

                    <RadioButton Content="حساب های بانکی"
                                 Style="{StaticResource ModernTabButton}"
                                 Margin="10,0,6,0"
                                 GroupName="ModernTabs"
                                 x:Name="TabInventory"
                                 Checked="TabInventory_Checked" />

                    <RadioButton Content="مالیات"
                                 Style="{StaticResource ModernTabButton}"
                                 Margin="10,0,6,0"
                                 GroupName="ModernTabs"
                                 x:Name="TabTax"
                                 Checked="TabTax_Checked" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid x:Name="PricingContent">
                    
                    <TextBlock Text="محتوای تماس و آدرس" />
                </Grid>

                <Grid x:Name="InventoryContent"
                      Visibility="Collapsed">
                    
                    <TextBlock Text="محتوای حساب های بانکی" />
                </Grid>

                <Grid x:Name="TaxContent"
                      Visibility="Collapsed">
                    
                    <TextBlock Text="محتوای مالیات" />
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
