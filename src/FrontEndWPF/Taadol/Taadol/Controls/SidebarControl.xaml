<UserControl x:Class="Taadol.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Taadol.Controls"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft"
             ClipToBounds="False">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Taadol;component/Controls/SubmenuStyles1.xaml" />
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="#F8FAFF"
            BorderBrush="#D4E1FF"
            x:Name="SidebarBorder"
            BorderThickness="1,0,0,0"
            ClipToBounds="False">

        <Grid ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>




            <Button x:Name="BtnToggleSidebar"
                    Click="BtnToggleSidebar_Click"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="999"
                    Margin="0,102,-13,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="toggleBorder"
                                Background="White"
                                CornerRadius="4"
                                Width="28"
                                Height="28">

                            <Border.Effect>
                                <DropShadowEffect Color="#6366F1"
                                                  BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Opacity="0.25"
                                                  Direction="315" />
                            </Border.Effect>

                            <svg:SvgViewbox x:Name="ToggleArrowIcon"
                                            Width="5"
                                            Height="8"
                                            Source="/Assets/Icons/ArrowLeft.svg"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RenderTransformOrigin="0.5,0.5">
                                <svg:SvgViewbox.RenderTransform>
                                    <RotateTransform x:Name="ArrowRotation"
                                                     Angle="180" />
                                </svg:SvgViewbox.RenderTransform>
                            </svg:SvgViewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="toggleBorder"
                                        Property="BorderBrush"
                                        Value="#7DA4FF" />
                                <Setter TargetName="toggleBorder"
                                        Property="BorderThickness"
                                        Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="toggleBorder"
                                        Property="Background"
                                        Value="#D4E1FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>




            <StackPanel Grid.Row="0">


                <StackPanel x:Name="LogoExpanded"
                            Orientation="Horizontal"
                            Margin="13,16,0,0"
                            HorizontalAlignment="Left">
                    <Border Width="45"
                            Height="48"
                            Background="Transparent">
                        <svg:SvgViewbox FlowDirection="LeftToRight"
                                        Source="/Assets/Icons/taa.svg"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                    </Border>
                    <!--<TextBlock x:Name="LogoText"
                               Text="تعادل"
                               FontSize="30"
                               FontWeight="DemiBold"
                               Foreground="#001182"
                               FontFamily="{StaticResource IRANSans}"
                               VerticalAlignment="Center"
                               Margin="13,0,0,0" />-->
                </StackPanel>

                <TextBlock x:Name="LogoText"
                           Text="نرم افزار حسابداری تعادل"
                           FontSize="11"
                           FontWeight="Medium"
                           Foreground="#0D2159"
                           FontFamily="{StaticResource IRANSans}"
                           VerticalAlignment="Center"
                           Margin="13,0,0,10" />
                <!-- ★ سلکتور سال مالی (UserControl مستقل — برای ویرایش ظاهر، فایل Controls/YearSelectorControl.xaml رو ببینید) -->
                <local:YearSelectorControl x:Name="YearSelector"
                                           HorizontalAlignment="Stretch" />

              
            </StackPanel>




