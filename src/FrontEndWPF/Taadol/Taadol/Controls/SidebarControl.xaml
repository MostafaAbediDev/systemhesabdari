                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,0"
                                                Margin="8,0,8,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <svg:SvgViewbox Width="18"
                                                                Height="18"
                                                                Source="/Assets/Icons/share_u.svg"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,10,0" />
                                                <TextBlock x:Name="txtSales"
                                                           Grid.Column="1"
                                                           Text="عملیات خرید و فروش"
                                                           FontSize="13"
                                                           FontWeight="Regular"
                                                           Foreground="#0D2159"
                                                           FontFamily="{StaticResource IRANSans}"
                                                           VerticalAlignment="Center" />
                                                <svg:SvgViewbox x:Name="chevSales"
                                                                Width="10"
                                                                Height="10"
                                                                Grid.Column="2"
                                                                Source="/Assets/Icons/ArrowUp.svg"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                RenderTransformOrigin="0.5,0.5">
                                                    <svg:SvgViewbox.RenderTransform>
                                                        <RotateTransform x:Name="rotSales"
                                                                         Angle="0" />
                                                    </svg:SvgViewbox.RenderTransform>
                                                </svg:SvgViewbox>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="bd"
                                                        Property="Background"
                                                        Value="#E9F0FF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel x:Name="SubSales"
                                        Visibility="Collapsed">
                                <Grid Style="{StaticResource SubmenuWrapper}"
                                      Background="Transparent"
                                      VerticalAlignment="Top">

                                    <Border Style="{StaticResource SubmenuBackground}"
                                            Panel.ZIndex="0" />

                                    <StackPanel Panel.ZIndex="1">

                                        <Border Style="{StaticResource SubmenuDivider}"
                                                Margin="0,15,0,0" />

                                        <Button Content="فاکتور خرید"
                                                Click="SubMenuClick"
                                                Tag="invoice_purchase"
                                                Style="{StaticResource SubmenuItem}" />

                                        <Button Content="فاکتور فروش"
                                                Click="SubMenuClick"
                                                Tag="invoice_sale"
                                                Style="{StaticResource SubmenuItem}" />

                                        <Border Height="6" />

                                    </StackPanel>


                                    <Ellipse Style="{StaticResource SubmenuEllipseLeft}"
                                             Panel.ZIndex="2"
                                             IsHitTestVisible="False" />

                                    <Ellipse Style="{StaticResource SubmenuEllipseRight}"
                                             Panel.ZIndex="2"
                                             IsHitTestVisible="False" />
                                </Grid>
                            </StackPanel>

                        </StackPanel>


                        <StackPanel x:Name="MenuReports"
                                    Grid.Row="7"
                                    Margin="0,10,0,0">
                            <Button x:Name="BtnReports"
                                    Click="ExpanderClick"
                                    Tag="reports"
                                    Height="44"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,0"
                                                Margin="8,0,8,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <svg:SvgViewbox Width="18"
                                                                Height="18"
                                                                Source="/Assets/Icons/rep_u.svg"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,10,0" />
                                                <TextBlock x:Name="txtReports"
                                                           Grid.Column="1"
                                                           Text="گزارش ها"
                                                           FontSize="13"
                                                           FontWeight="Regular"
                                                           Foreground="#0D2159"
                                                           FontFamily="{StaticResource IRANSans}"
                                                           VerticalAlignment="Center" />
                                                <svg:SvgViewbox x:Name="chevReports"
                                                                Width="10"
                                                                Height="10"
                                                                Grid.Column="2"
                                                                Source="/Assets/Icons/ArrowUp.svg"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                RenderTransformOrigin="0.5,0.5">
                                                    <svg:SvgViewbox.RenderTransform>
                                                        <RotateTransform x:Name="rotReports"
                                                                         Angle="0" />
                                                    </svg:SvgViewbox.RenderTransform>
                                                </svg:SvgViewbox>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="bd"
                                                        Property="Background"
                                                        Value="#E9F0FF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel x:Name="SubReports"
                                        Visibility="Collapsed">
                                <Grid Style="{StaticResource SubmenuWrapper}"
                                      VerticalAlignment="Top"
                                      Background="Transparent">

                                    <Border Style="{StaticResource SubmenuBackground}"
                                            Panel.ZIndex="0" />

                                    <StackPanel Panel.ZIndex="1">

                                        <Border Style="{StaticResource SubmenuDivider}"
                                                Margin="0,15,0,0" />

                                        <Button Content="گزارش فروش"
                                                Tag="report_sales"
                                                Click="SubMenuClick"
                                                Style="{StaticResource SubmenuItem}" />

                                        <Button Content="گزارش مالی"
                                                Tag="report_financial"
                                                Click="SubMenuClick"
                                                Style="{StaticResource SubmenuItem}" />

                                        <Border Height="6" />

                                    </StackPanel>


                                    <Ellipse Style="{StaticResource SubmenuEllipseLeft}"
                                             Panel.ZIndex="2"
                                             IsHitTestVisible="False" />

                                    <Ellipse Style="{StaticResource SubmenuEllipseRight}"
                                             Panel.ZIndex="2"
                                             IsHitTestVisible="False" />
                                </Grid>
                            </StackPanel>

                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
