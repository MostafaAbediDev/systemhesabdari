<UserControl x:Class="Taadol.Controls.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FontFamily="{StaticResource IRANSans}"
             HorizontalAlignment="Center"
             Width="500"
             Margin="0,0,0,10"
             Opacity="0"
             FlowDirection="RightToLeft"
             RenderTransformOrigin="0.5,0">
    <UserControl.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" Y="-60" />
    </UserControl.RenderTransform>

    <Border x:Name="RootBorder"
            Background="White"
            CornerRadius="12"
            Padding="18,14"
            RenderTransformOrigin="0.5,0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32"
                              ShadowDepth="0"
                              Opacity="0.18"
                              Color="#0F1B4C"
                              Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- آیکون توی دایره رنگی -->
            <Border x:Name="IconCircle"
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    CornerRadius="4"
                    VerticalAlignment="Center">
                <Border x:Name="IconInner"
                        Width="32"
                        Height="32"
                        CornerRadius="4"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <svg:SvgViewbox x:Name="IconSvg"
                                    FlowDirection="LeftToRight"
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>
            </Border>

            <!-- متن -->
            <TextBlock x:Name="MessageText"
                       Grid.Column="2"
                       FontSize="13.5"
                       FontWeight="Medium"
                       Foreground="#1E293B"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       LineHeight="21" />

            <!-- دکمه بستن -->
            <Border x:Name="CloseBorder"
                    Grid.Column="3"
                    Visibility="Collapsed"
                    Width="26"
                    Height="26"
                    CornerRadius="13"
                    Background="Transparent"
                    VerticalAlignment="Top"
                    Cursor="Hand"
                    Margin="6,0,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=CloseCommand}" />
                </Border.InputBindings>
                <Canvas Width="10" Height="10">
                    <Line X1="1" Y1="1" X2="9" Y2="9"
                          Stroke="#94A3B8" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <Line X1="9" Y1="1" X2="1" Y2="9"
                          Stroke="#94A3B8" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                </Canvas>
            </Border>
        </Grid>
    </Border>
</UserControl>
