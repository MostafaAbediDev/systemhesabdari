<Window x:Class="Taadol.Controls.ModernDialog"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
         WindowStyle="None"
         FontFamily="{StaticResource IRANSans}"
         AllowsTransparency="True"
         Background="Transparent"
         WindowStartupLocation="CenterOwner"
         ShowInTaskbar="False"
         Topmost="True"
         SizeToContent="Height"
         Width="440"
         MinHeight="280"
         FlowDirection="RightToLeft">

    <Border x:Name="RootBorder"
            Background="White"
            CornerRadius="4"
            Padding="30,28"
            Margin="20"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale"
                            ScaleX="0.85"
                            ScaleY="0.85" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="RootShadow"
                              BlurRadius="32"
                              ShadowDepth="0"
                              Opacity="0.18"
                              Color="#0F1B4C"
                              Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ====== آیکون بزرگ در دایره رنگی ====== -->
            <Border x:Name="IconCircle"
                    Grid.Row="0"
                    Width="76"
                    Height="76"
                    CornerRadius="4"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,18">
                <Border x:Name="IconInner"
                        Width="44"
                        Height="44"
                        CornerRadius="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <svg:SvgViewbox x:Name="DialogIcon"
                                    Width="26"
                                    Height="26"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="/Assets/Icons/trash.svg" />
                </Border>
            </Border>

            <!-- ====== عنوان ====== -->
            <TextBlock x:Name="DialogTitle"
                       Grid.Row="1"
                       Text="عنوان"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E63946"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />

            <!-- ====== توضیح ====== -->
            <TextBlock x:Name="DialogMessage"
                       Grid.Row="2"
                       Text="پیام توضیحی در اینجا قرار می‌گیرد."
                       FontSize="13"
                       Foreground="#6B7280"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="10,0,10,18"
                       LineHeight="22" />

            <!-- ====== TextBox (فقط در حالت Input نمایش داده می‌شود) ====== -->
            <Border x:Name="InputWrapper"
                    Grid.Row="3"
                    Visibility="Collapsed"
                    Background="#F8FAFF"
                    BorderBrush="#D4E1FF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,18"
                    Padding="14,0">
                <TextBox x:Name="InputBox"
                         FontFamily="{StaticResource IRANSans}"
                         FontSize="14"
                         Foreground="#0D2159"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         Height="40"
                         KeyDown="InputBox_KeyDown" />
            </Border>

            <!-- ====== دکمه‌ها ====== -->
            <StackPanel Grid.Row="4"
                        x:Name="ButtonsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0">

                <!-- دکمه تأیید -->
                <Button x:Name="ConfirmButton"
                        Width="130"
                        Height="42"
                        Margin="6,0"
                        Click="Confirm_Click"
                        Cursor="Hand"
                        Background="#E63946">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ConfirmBd"
                                    CornerRadius="12"
                                    Background="Transparent">
                                <Border x:Name="ConfirmBdInner"
                                        CornerRadius="12"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="ConfirmBd"
                                            Property="Opacity"
                                            Value="0.92" />
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="ConfirmBdInner"
                                            Property="Opacity"
                                            Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="ConfirmText"
                               Text="تأیید"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Medium" />
                </Button>

                <!-- دکمه انصراف -->
                <Button x:Name="CancelButton"
                        Width="130"
                        Height="42"
                        Margin="6,0"
                        Click="Cancel_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CancelBd"
                                    CornerRadius="12"
                                    Background="White"
                                    BorderBrush="#D4E1FF"
                                    BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="CancelBd"
                                            Property="Background"
                                            Value="#F8FAFF" />
                                    <Setter TargetName="CancelBd"
                                            Property="BorderBrush"
                                            Value="#A5B4FC" />
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="CancelBd"
                                            Property="Opacity"
                                            Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="CancelText"
                               Text="انصراف"
                               Foreground="#2563EB"
                               FontSize="13"
                               FontWeight="Medium" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>