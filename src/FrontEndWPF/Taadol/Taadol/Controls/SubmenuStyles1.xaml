<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="SubmenuWrapper"
           TargetType="Grid">
        <Setter Property="Background"
                Value="Transparent" />
    </Style>

    <Style x:Key="SubmenuBackground"
           TargetType="Border">
        <Setter Property="Background"
                Value="#E9F0FF" />
        <Setter Property="IsHitTestVisible"
                Value="False" />
        <Setter Property="CornerRadius"
                Value="0,0,8,8" />
        <Setter Property="Padding"
                Value="0,8" />
        <Setter Property="Margin"
                Value="8,0,8,0" />
    </Style>

    <!-- ★ خط چین بین دو دایره — با Padding 18 از هر طرف فاصله داره -->
    <Style x:Key="SubmenuDivider"
           TargetType="Border">
        <Setter Property="Height"
                Value="1" />
        <Setter Property="Margin"
                Value="0,9,0,6" />
        <Setter Property="Padding"
                Value="18,0,18,0" />
        <Setter Property="Background">
            <Setter.Value>
                <VisualBrush TileMode="Tile"
                             Viewport="0,0,4,1"
                             ViewportUnits="Absolute"
                             Viewbox="0,0,4,1"
                             ViewboxUnits="Absolute">
                    <VisualBrush.Visual>
                        <Grid Width="4"
                              Height="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2" />
                                <ColumnDefinition Width="2" />
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0"
                                       Fill="#2667FF"
                                       RadiusX="1"
                                       RadiusY="1" />
                            <Rectangle Grid.Column="1"
                                       Fill="Transparent" />
                        </Grid>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SubmenuEllipseLeft"
           TargetType="Ellipse">
        <Setter Property="Width"
                Value="17" />
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Fill"
                Value="#F8FAFF" />
        <Setter Property="HorizontalAlignment"
                Value="Left" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="-3,4,0,0" />
        <Setter Property="IsHitTestVisible"
                Value="False" />
    </Style>

    <Style x:Key="SubmenuEllipseRight"
           TargetType="Ellipse">
        <Setter Property="Width"
                Value="17" />
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Fill"
                Value="#F8FAFF" />
        <Setter Property="HorizontalAlignment"
                Value="Right" />
        <Setter Property="VerticalAlignment"
                Value="Top" />
        <Setter Property="Margin"
                Value="0,4,-3,0" />
        <Setter Property="IsHitTestVisible"
                Value="False" />
    </Style>

    <Style x:Key="SubmenuItem"
           TargetType="Button">
        <Setter Property="Height"
                Value="36" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="Background"
                Value="Transparent" />
        <Setter Property="BorderThickness"
                Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            Margin="20,1,12,1"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    Margin="8,0">

                            <Ellipse x:Name="PART_Dot"
                                     Width="5"
                                     Height="5"
                                     Fill="#737791"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0" />

                            <TextBlock x:Name="PART_Text"
                                       Text="{TemplateBinding Content}"
                                       FontSize="14"
                                       FontWeight="Regular"
                                       Foreground="#737791"
                                       FontFamily="{StaticResource IRANSans}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="PART_Text"
                                    Property="Foreground"
                                    Value="#2A3547" />
                            <Setter TargetName="PART_Text"
                                    Property="FontWeight"
                                    Value="Regular" />
                            <Setter TargetName="PART_Dot"
                                    Property="Fill"
                                    Value="#2A3547" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
