<UserControl x:Class="Taadol.Controls.YearSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style x:Key="YearButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="40" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Stretch" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="FontFamily"
                    Value="{StaticResource IRANSans}" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="Medium" />
            <Setter Property="Foreground"
                    Value="#737791" />
            <Setter Property="Padding"
                    Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- ★ FlowDirection و TextBlock.TextAlignment مستقیم روی Border -->
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                FlowDirection="RightToLeft">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              TextBlock.TextAlignment="Left"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E9F0FF" />
                                <Setter Property="Foreground"
                                        Value="#0D2159" />
                                <Setter Property="FontWeight"
                                        Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="YearButtonSelectedStyle"
               TargetType="Button"
               BasedOn="{StaticResource YearButtonStyle}">
            <Setter Property="Background"
                    Value="#E9F0FF" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Foreground"
                    Value="#0D2159" />
        </Style>

        <Style x:Key="YearDividerStyle"
               TargetType="Border">
            <Setter Property="Height"
                    Value="1" />
            <Setter Property="Margin"
                    Value="12,2" />
            <Setter Property="Background"
                    Value="#E2E8F0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ★ سلکتور اصلی (هدر) — دیگه BorderBrush/BorderThickness نداره، خط از IconLineWrapper میاد -->
        <Border x:Name="SelectorBorder"
                Background="Transparent"
                Padding="0,8"
                Margin="12,0,12,0"
                BorderBrush="#2667FF"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True"
                BorderThickness="0,1,0,1"
                Cursor="Hand"
                HorizontalAlignment="Stretch"
                MouseLeftButtonUp="Selector_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <svg:SvgViewbox Grid.Column="0"
                                Margin="10,0,10,0"
                                Width="18"
                                FlowDirection="LeftToRight"
                                Height="18"
                                Stretch="Uniform"
                                Source="/Assets/Icons/calendar-tick.svg"
                                VerticalAlignment="Center" />
                <TextBlock x:Name="YearText"
                           Grid.Column="1"
                           Text="در حال بارگذاری..."
                           FontSize="13"
                           FontWeight="Medium"
                           Foreground="#737791"
                           FontFamily="{StaticResource IRANSans}"
                           HorizontalAlignment="Stretch"
                           FlowDirection="RightToLeft"
                          />
                <svg:SvgViewbox Grid.Column="2"
                                x:Name="Chevron"
                                Margin="0,0,10,0"
                                MouseLeftButtonUp="Selector_Click"
                                Width="10"
                                Height="4"
                                Stretch="Uniform"
                                Source="/Assets/Icons/Arrow.svg"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                    <svg:SvgViewbox.RenderTransform>
                        <RotateTransform x:Name="ChevronRotation"
                                         Angle="0" />
                    </svg:SvgViewbox.RenderTransform>
                </svg:SvgViewbox>
            </Grid>
        </Border>

        <!-- ★ پاپ‌آپ لیست سال‌ها -->
        <Popup x:Name="YearsPopup"
               PlacementTarget="{Binding ElementName=SelectorBorder}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Closed="YearsPopup_Closed"
               FlowDirection="RightToLeft">
            <Border Background="White"
                    BorderBrush="#D4E1FF"
                    BorderThickness="1"
                    CornerRadius="0,0,8,8"
                    Width="220"
                    Padding="4"
                    FlowDirection="RightToLeft">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="2"
                                      Opacity="0.12"
                                      Color="#001242"
                                      Direction="270" />
                </Border.Effect>

                <Grid>
                    <Border x:Name="LoadingOverlay"
                            Background="White"
                            CornerRadius="0,0,8,8"
                            Visibility="Collapsed"
                            Padding="0,12">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Grid Width="24"
                                  Height="24"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotation"
                                                     Angle="0" />
                                </Grid.RenderTransform>
                                <Ellipse Width="20"
                                         Height="20"
                                         Stroke="#D4E0FF"
                                         StrokeThickness="3" />
                                <Path Stroke="#2667FF"
                                      StrokeThickness="3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M 11,1 A 10,10 0 0 1 21,11" />
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Grid.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0"
                                                                 To="360"
                                                                 Duration="0:0:0.8" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                            </Grid>
                            <TextBlock Text="در حال بارگذاری..."
                                       FontFamily="{StaticResource IRANSans}"
                                       FontSize="11"
                                       Foreground="#737791"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="YearsList"
                                Visibility="Visible"
                                FlowDirection="RightToLeft" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>