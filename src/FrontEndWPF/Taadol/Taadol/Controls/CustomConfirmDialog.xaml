<Window x:Class="Taadol.Controls.CustomConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="http://sharpvectors.codeplex.com/svgc/"
        WindowStyle="None"
        FontFamily="{StaticResource IRANSans}"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="420"
        Height="260"
        
        Topmost="True">

    <Border Background="White"
            CornerRadius="18"
            Padding="25">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ICON -->
            <Border Width="40"
                    Height="40"
                    Background="#E9FFF1"
                    CornerRadius="8"
                    HorizontalAlignment="Center">

                <svg:SvgViewbox Width="24"
                                Height="24"
                                Source="/Assets/Icons/save_p.svg"
                                VerticalAlignment="Center" />
            </Border>

            <!-- TEXT -->
            <StackPanel Grid.Row="1"
                        Margin="0,15,0,0"
                        HorizontalAlignment="Center">

                <TextBlock Text="ثبت اطلاعات"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#22C55E"
                           HorizontalAlignment="Center" />

                <TextBlock Text="اطلاعات وارد شده بررسی شد. با ثبت، این مورد به سیستم اضافه می‌شود."
                           FontSize="13"
                           Foreground="#6B7280"
                           FlowDirection="RightToLeft"
                           TextAlignment="Center"
                           Margin="0,10,0,0"
                           Width="300"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- BUTTONS -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button Width="104"
                        Height="36"
                        Margin="5"
                        Click="Confirm_Click"
                        Background="#22C55E"
                        Foreground="White"
                        BorderThickness="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    CornerRadius="8"
                                    Background="{TemplateBinding Background}">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="bd"
                                            Property="Background"
                                            Value="#16A34A" />
                                </Trigger>

                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="bd"
                                            Property="Opacity"
                                            Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>

                    <TextBlock Text="ثبت اطلاعات" FontWeight="Medium" />
                </Button>
                <Button Width="104"
                        Height="36"
                        Margin="5"
                        Click="Cancel_Click"
                        Background="Transparent"
                        BorderBrush="#A5B4FC"
                        Foreground="#2563EB">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    CornerRadius="8"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="bd"
                                            Property="Background"
                                            Value="#EEF2FF" />
                                </Trigger>

                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="bd"
                                            Property="Opacity"
                                            Value="0.8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>

                    <TextBlock Text="منصرف شدم."
                               FlowDirection="RightToLeft"
                               FontWeight="Medium" />
                </Button>

              
            </StackPanel>

        </Grid>
    </Border>
</Window>