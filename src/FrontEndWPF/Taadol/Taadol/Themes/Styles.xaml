                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="OuterCircle"
                                    Property="Stroke"
                                    Value="#1E8449" />
                            <Setter TargetName="OuterCircle"
                                    Property="Fill"
                                    Value="#E8F8F0" />
                        </Trigger>

                        
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter TargetName="OuterCircle"
                                    Property="Stroke"
                                    Value="#A9DFBF" />
                            <Setter TargetName="InnerCircle"
                                    Property="Fill"
                                    Value="#A9DFBF" />
                            <Setter Property="Foreground"
                                    Value="#A9DFBF" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
